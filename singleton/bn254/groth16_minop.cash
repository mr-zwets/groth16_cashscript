        (int cl0,int cl1,int cl2,int cl3,int cl4,int cl5) = fp6MulRaw(F0,F1,F2,F3,F4,F5, t10+t30,t11+t31,t12+t32,t13+t33,t14+t34,t15+t35);
        (int cr0,int cr1,int cr2,int cr3,int cr4,int cr5) = fp6MulRaw(F6,F7,F8,F9,F10,F11, 1+9*q4-q5, q4+9*q5, q0, q1, q2, q3);
        require(mulFp(cl0 - cr0, 1) == 0); require(mulFp(cl1 - cr1, 1) == 0); require(mulFp(cl2 - cr2, 1) == 0); require(mulFp(cl3 - cr3, 1) == 0); require(mulFp(cl4 - cr4, 1) == 0); require(mulFp(cl5 - cr5, 1) == 0);
    }
}
