pragma cashscript ^0.13.0;

// LIBRARY-SYSTEM DEMONSTRATOR for the FULL BN254 Groth16 verifier. The entire implementation —
// field tower (Fp..Fp12), Miller loop + G2 subgroup check, final exponentiation, and G1 scalar mult —
// comes from imported libraries; the contract body is only spend() (proof/G2-subgroup validation,
// on-chain vk_x, and the 4-pair pairing-product == 1 check). Graded by singleton/pairing/groth16.mjs.
import "./lib/Miller.cash";
import "./lib/FinalExp.cash";
import "./lib/G1.cash";

contract Groth16Verify() {
    function spend(
        int Ax, int Ay, int Bxa, int Bxb, int Bya, int Byb, int Cx, int Cy,
        int in0, int in1
    ) {
        // ---- validate spender-supplied proof points (EIP-197 rigor) ----
        require(mulFp(Ay, Ay) == addFp(mulFp(mulFp(Ax, Ax), Ax), 3)); // A on G1
        require(mulFp(Cy, Cy) == addFp(mulFp(mulFp(Cx, Cx), Cx), 3)); // C on G1
        (int bx2a,int bx2b) = fp2Sqr(Bxa, Bxb);                       // B on G2: y^2 == x^3 + b2
        (int bx3a,int bx3b) = fp2Mul(bx2a, bx2b, Bxa, Bxb);
        (int onrhsa,int onrhsb) = fp2Add(bx3a, bx3b,
            19485874751759354771024239261021720505790618469301721065564631296452457478373,
            266929791119991161246907387137283842545076965332900288569378510910307636690);
        (int by2a,int by2b) = fp2Sqr(Bya, Byb);
        require(by2a == onrhsa); require(by2b == onrhsb);
        int RXa=0; int RXb=0; int RYa=1; int RYb=0; int RZa=0; int RZb=0; // [6x^2]B (Jacobian)
        for (int i = 0; i < 128; i = i + 1) {
            (int da,int db,int dc,int dd,int de,int df) = g2Double(RXa, RXb, RYa, RYb, RZa, RZb);
            RXa=da; RXb=db; RYa=dc; RYb=dd; RZa=de; RZb=df;
            if (((147946756881789318990833708069417712966 >> (127 - i)) % 2) == 1) {
                (int aa,int ab,int ac,int ad,int ae,int af) = g2AddAffine(RXa, RXb, RYa, RYb, RZa, RZb, Bxa, Bxb, Bya, Byb);
                RXa=aa; RXb=ab; RYa=ac; RYb=ad; RZa=ae; RZb=af;
            }
        }
        (int psxa,int psxb,int psya,int psyb) = psi(Bxa, Bxb, Bya, Byb); // require [6x^2]B == psi(B)
        (int sz2a,int sz2b) = fp2Sqr(RZa, RZb);
        (int sz3a,int sz3b) = fp2Mul(sz2a, sz2b, RZa, RZb);
        (int cx_a,int cx_b) = fp2Mul(psxa, psxb, sz2a, sz2b);
        (int cy_a,int cy_b) = fp2Mul(psya, psyb, sz3a, sz3b);
        require(RXa == cx_a); require(RXb == cx_b);
        require(RYa == cy_a); require(RYb == cy_b);

        // vk_x = IC0 + in0*IC1 + in1*IC2
        (int r1x, int r1y, int r1z) = g1ScalarMul(in0,
            9269869340829791644953940526610795845982127221382366381974052273854848284744,
            12340830433822638848259976740304056841548514693917037023437897137808450264577);
        (int r2x, int r2y, int r2z) = g1ScalarMul(in1,
            6442706084407552401539720969529928260622245802604045626376932056434206076947,
            13805589277496019078136496656829548863642318729315912795941464570275337353000);
        (int a1x, int a1y, int a1z) = jacAddG1(
            15723390722547469201346605927630336729729463607293657950235977012003655267936,
            14617976463853845616027311884626760527376622737858716767193455441349641383825, 1,
            r1x, r1y, r1z);
        (int vx, int vy, int vz) = jacAddG1(a1x, a1y, a1z, r2x, r2y, r2z);
        (int vkxX, int vkxY) = jacToAffine(vx, vy, vz);

        // e(-A,B) * e(alpha,beta) * e(vk_x,gamma) * e(C,delta) == 1
        int nAy = subFp(0, Ay);
        (int m1_0,int m1_1,int m1_2,int m1_3,int m1_4,int m1_5,int m1_6,int m1_7,int m1_8,int m1_9,int m1_10,int m1_11) =
            millerSingle(Bxa, Bxb, Bya, Byb, Ax, nAy);
        (int m2_0,int m2_1,int m2_2,int m2_3,int m2_4,int m2_5,int m2_6,int m2_7,int m2_8,int m2_9,int m2_10,int m2_11) =
            millerSingle(
                17467917077997409920481960112226002748883030164933060982083570835869719819168,
                9543924542455805865677785465159349894279659454147026211356195301797094705807,
                20459688264762308310588269661274938525104694421730310554970214541176968393385,
                19465560217230762055900455536522601853894771406309777885817297488125148793229,
                14344921588710038019110518519527661247161785735962037005430040319326557952203,
                1404059666412774300404055719909964693738831005230889414572223472408856431918);
        (int m3_0,int m3_1,int m3_2,int m3_3,int m3_4,int m3_5,int m3_6,int m3_7,int m3_8,int m3_9,int m3_10,int m3_11) =
            millerSingle(
                13700863412905423759250606799218875849166292978636329233814994817818554546431,
                21761028412726985313317130874134828290145951226051416150723277301116006118078,
                21547676276454546410296902538495425432829390494566673627605034971294784210249,
                6398877257285935365249802814125273995578953055511620955996813742572019651748,
                vkxX, vkxY);
        (int m4_0,int m4_1,int m4_2,int m4_3,int m4_4,int m4_5,int m4_6,int m4_7,int m4_8,int m4_9,int m4_10,int m4_11) =
            millerSingle(
                15825285363846036862295217228464959249112247579247978462621447842724817286232,
                3543600181522862329564888283473085279940669956506060026762005346996341806108,
                21514667205241674535457714632061047258097217169787877277363751636045743019390,
                10670741793215758088800930336726579942257175283397977169474518534600570072949,
                Cx, Cy);
        (int ab0,int ab1,int ab2,int ab3,int ab4,int ab5,int ab6,int ab7,int ab8,int ab9,int ab10,int ab11) =
            fp12Mul(m1_0,m1_1,m1_2,m1_3,m1_4,m1_5,m1_6,m1_7,m1_8,m1_9,m1_10,m1_11, m2_0,m2_1,m2_2,m2_3,m2_4,m2_5,m2_6,m2_7,m2_8,m2_9,m2_10,m2_11);
        (int abc0,int abc1,int abc2,int abc3,int abc4,int abc5,int abc6,int abc7,int abc8,int abc9,int abc10,int abc11) =
            fp12Mul(ab0,ab1,ab2,ab3,ab4,ab5,ab6,ab7,ab8,ab9,ab10,ab11, m3_0,m3_1,m3_2,m3_3,m3_4,m3_5,m3_6,m3_7,m3_8,m3_9,m3_10,m3_11);
        (int bnd0,int bnd1,int bnd2,int bnd3,int bnd4,int bnd5,int bnd6,int bnd7,int bnd8,int bnd9,int bnd10,int bnd11) =
            fp12Mul(abc0,abc1,abc2,abc3,abc4,abc5,abc6,abc7,abc8,abc9,abc10,abc11, m4_0,m4_1,m4_2,m4_3,m4_4,m4_5,m4_6,m4_7,m4_8,m4_9,m4_10,m4_11);
        (int o0,int o1,int o2,int o3,int o4,int o5,int o6,int o7,int o8,int o9,int o10,int o11) =
            finalExp(bnd0,bnd1,bnd2,bnd3,bnd4,bnd5,bnd6,bnd7,bnd8,bnd9,bnd10,bnd11);
        require(o0==1); require(o1==0); require(o2==0); require(o3==0); require(o4==0); require(o5==0);
        require(o6==0); require(o7==0); require(o8==0); require(o9==0); require(o10==0); require(o11==0);
    }
}
