pragma cashscript ^0.13.0;

// BN254 final exponentiation f^((p^12-1)/r), transcribed from the proven JS spec
// finalexp_ref.mjs (== noble Fp12.finalExponentiate). Combined with the Miller
// boundary this is the full pairing verdict: finalExp(boundary) == 1 iff the
// Groth16 proof verifies (checkpoint #3).
//
// Easy part: r0 = conj(f)*inv(f); r = frob2(r0)*r0. Hard part: a fixed sequence
// of cyclotomic squarings, powMinusX = conj(cyclotomicExp(.,X)) (X = BN seed,
// 63 bits), conjugations and Frobenius maps. f carried as 12 ints (noble order).
// Graded vs noble Fp12.finalExponentiate by singleton/pairing/finalexp.mjs.
contract FinalExp() {

    // LAZY ADDITION + SUBTRACTION (option B): neither addFp nor subFp reduces.
    // subFp = x - y + k, k = K*p a per-call-site bias >= bound(y) so the result is
    // non-negative; K from bound_analysis.mjs. Structural subs (operands = local mulFp
    // outputs) get a small fixed K; subs whose result is consumed by a mulFp (negs,
    // cyclotomic z-terms, frobenius conjugates) carry a safe 64p bias (>= the 37p
    // global max carried bound). See miller.cash for the full rationale. Only mulFp
    // reduces; carried/hashed/asserted values are reduced (% p) at boundaries.
    internal function addFp(int x, int y) returns (int) { return x + y; }
    internal function subFp(int x, int y, int k) returns (int) { return x - y + k * 21888242871839275222246405745257275088696311157297823662689037894645226208583; }
    internal function mulFp(int x, int y) returns (int) { return (x * y) % 21888242871839275222246405745257275088696311157297823662689037894645226208583; }
    internal function inverseFp(int x) returns (int) {
        int p = 21888242871839275222246405745257275088696311157297823662689037894645226208583;
        int q = p - 2;
        int result = 1;
        int current = x % p;
        for (int i = 0; i < 254; i = i + 1) {
            if (((q >> i) % 2) == 1) { result = (result * current) % p; }
            current = (current * current) % p;
        }
        return result;
    }

    // ---- Fp2 ----
    internal function fp2Add(int a0, int a1, int b0, int b1) returns (int, int) { return addFp(a0, b0), addFp(a1, b1); }
    internal function fp2Sub(int a0, int a1, int b0, int b1, int k) returns (int, int) { return subFp(a0, b0, k), subFp(a1, b1, k); }
    internal function fp2Neg(int a0, int a1, int k) returns (int, int) { return subFp(0, a0, k), subFp(0, a1, k); }
    internal function fp2Scale(int a0, int a1, int k) returns (int, int) { return mulFp(a0, k), mulFp(a1, k); }
    internal function fp2Mul(int a0, int a1, int b0, int b1) returns (int, int) {
        int v0 = mulFp(a0, b0);
        int v1 = mulFp(a1, b1);
        return subFp(v0, v1, 1),
               subFp(mulFp(addFp(a0, a1), addFp(b0, b1)), addFp(v0, v1), 2);
    }
    internal function fp2Sqr(int a0, int a1) returns (int, int) {
        return mulFp(addFp(a0, a1), subFp(a0, a1, 64)), mulFp(2, mulFp(a0, a1));
    }
    internal function fp2MulXi(int a0, int a1, int k) returns (int, int) { return subFp(mulFp(9, a0), a1, k), addFp(mulFp(9, a1), a0); }
    internal function fp2Conj(int a0, int a1, int k) returns (int, int) { return a0, subFp(0, a1, k); }
    internal function fp2Inv(int a0, int a1) returns (int, int) {
        int factor = inverseFp(addFp(mulFp(a0, a0), mulFp(a1, a1)));
        return mulFp(a0, factor), subFp(0, mulFp(a1, factor), 1);
    }

    // ---- Fp6 ----
    internal function fp6Add(int a0a,int a0b,int a1a,int a1b,int a2a,int a2b,int b0a,int b0b,int b1a,int b1b,int b2a,int b2b) returns (int,int,int,int,int,int) {
        (int c0a, int c0b) = fp2Add(a0a, a0b, b0a, b0b);
        (int c1a, int c1b) = fp2Add(a1a, a1b, b1a, b1b);
        (int c2a, int c2b) = fp2Add(a2a, a2b, b2a, b2b);
        return c0a, c0b, c1a, c1b, c2a, c2b;
    }
    internal function fp6Sub(int a0a,int a0b,int a1a,int a1b,int a2a,int a2b,int b0a,int b0b,int b1a,int b1b,int b2a,int b2b, int k) returns (int,int,int,int,int,int) {
        (int c0a, int c0b) = fp2Sub(a0a, a0b, b0a, b0b, k);
        (int c1a, int c1b) = fp2Sub(a1a, a1b, b1a, b1b, k);
        (int c2a, int c2b) = fp2Sub(a2a, a2b, b2a, b2b, k);
        return c0a, c0b, c1a, c1b, c2a, c2b;
    }
    internal function fp6Neg(int a0a,int a0b,int a1a,int a1b,int a2a,int a2b, int k) returns (int,int,int,int,int,int) {
        (int c0a, int c0b) = fp2Neg(a0a, a0b, k);
        (int c1a, int c1b) = fp2Neg(a1a, a1b, k);
        (int c2a, int c2b) = fp2Neg(a2a, a2b, k);
        return c0a, c0b, c1a, c1b, c2a, c2b;
    }
    internal function fp6MulByV(int a0a,int a0b,int a1a,int a1b,int a2a,int a2b, int k) returns (int,int,int,int,int,int) {
        (int n0a, int n0b) = fp2MulXi(a2a, a2b, k);
        return n0a, n0b, a0a, a0b, a1a, a1b;
    }
    // structural: d* = 3p, x1 = 9p, x2 = 3p (operands are local fp2Mul outputs).
    internal function fp6Mul(int a0a,int a0b,int a1a,int a1b,int a2a,int a2b,int b0a,int b0b,int b1a,int b1b,int b2a,int b2b) returns (int,int,int,int,int,int) {
        (int t0a, int t0b) = fp2Mul(a0a, a0b, b0a, b0b);
        (int t1a, int t1b) = fp2Mul(a1a, a1b, b1a, b1b);
        (int t2a, int t2b) = fp2Mul(a2a, a2b, b2a, b2b);
        (int s1a, int s1b) = fp2Add(a1a, a1b, a2a, a2b);
        (int s2a, int s2b) = fp2Add(b1a, b1b, b2a, b2b);
        (int p1a, int p1b) = fp2Mul(s1a, s1b, s2a, s2b);
        (int d1a, int d1b) = fp2Sub(p1a, p1b, t1a, t1b, 3);
        (int d2a, int d2b) = fp2Sub(d1a, d1b, t2a, t2b, 3);
        (int x1a, int x1b) = fp2MulXi(d2a, d2b, 9);
        (int c0a, int c0b) = fp2Add(t0a, t0b, x1a, x1b);
        (int s3a, int s3b) = fp2Add(a0a, a0b, a1a, a1b);
        (int s4a, int s4b) = fp2Add(b0a, b0b, b1a, b1b);
        (int p2a, int p2b) = fp2Mul(s3a, s3b, s4a, s4b);
        (int d3a, int d3b) = fp2Sub(p2a, p2b, t0a, t0b, 3);
        (int d4a, int d4b) = fp2Sub(d3a, d3b, t1a, t1b, 3);
        (int x2a, int x2b) = fp2MulXi(t2a, t2b, 3);
        (int c1a, int c1b) = fp2Add(d4a, d4b, x2a, x2b);
        (int s5a, int s5b) = fp2Add(a0a, a0b, a2a, a2b);
        (int s6a, int s6b) = fp2Add(b0a, b0b, b2a, b2b);
        (int p3a, int p3b) = fp2Mul(s5a, s5b, s6a, s6b);
        (int d5a, int d5b) = fp2Sub(p3a, p3b, t0a, t0b, 3);
        (int d6a, int d6b) = fp2Sub(d5a, d5b, t2a, t2b, 3);
        (int c2a, int c2b) = fp2Add(d6a, d6b, t1a, t1b);
        return c0a, c0b, c1a, c1b, c2a, c2b;
    }
    internal function fp6Inv(int c0a,int c0b,int c1a,int c1b,int c2a,int c2b) returns (int,int,int,int,int,int) {
        (int sq0a,int sq0b) = fp2Sqr(c0a, c0b);
        (int m21a,int m21b) = fp2Mul(c2a, c2b, c1a, c1b);
        (int xm21a,int xm21b) = fp2MulXi(m21a, m21b, 3);
        (int t0a,int t0b) = fp2Sub(sq0a, sq0b, xm21a, xm21b, 4);
        (int sq2a,int sq2b) = fp2Sqr(c2a, c2b);
        (int xsq2a,int xsq2b) = fp2MulXi(sq2a, sq2b, 1);
        (int m01a,int m01b) = fp2Mul(c0a, c0b, c1a, c1b);
        (int t1a,int t1b) = fp2Sub(xsq2a, xsq2b, m01a, m01b, 3);
        (int sq1a,int sq1b) = fp2Sqr(c1a, c1b);
        (int m02a,int m02b) = fp2Mul(c0a, c0b, c2a, c2b);
        (int t2a,int t2b) = fp2Sub(sq1a, sq1b, m02a, m02b, 3);
        (int ct1a,int ct1b) = fp2Mul(c2a, c2b, t1a, t1b);
        (int ct2a,int ct2b) = fp2Mul(c1a, c1b, t2a, t2b);
        (int suma,int sumb) = fp2Add(ct1a, ct1b, ct2a, ct2b);
        (int xa,int xb) = fp2MulXi(suma, sumb, 6);
        (int c0t0a,int c0t0b) = fp2Mul(c0a, c0b, t0a, t0b);
        (int na,int nb) = fp2Add(xa, xb, c0t0a, c0t0b);
        (int fa,int fb) = fp2Inv(na, nb);
        (int r0a,int r0b) = fp2Mul(fa, fb, t0a, t0b);
        (int r1a,int r1b) = fp2Mul(fa, fb, t1a, t1b);
        (int r2a,int r2b) = fp2Mul(fa, fb, t2a, t2b);
        return r0a, r0b, r1a, r1b, r2a, r2b;
    }
    // Fp6 Frobenius helpers (odd power = conjugate fp2 frob; even = identity) + scale by Fp2 const
    internal function fp6FrobOdd(int x0a,int x0b,int x1a,int x1b,int x2a,int x2b, int k1a,int k1b,int k2a,int k2b) returns (int,int,int,int,int,int) {
        (int d0a,int d0b) = fp2Conj(x0a, x0b, 64);
        (int c1a,int c1b) = fp2Conj(x1a, x1b, 64);
        (int d1a,int d1b) = fp2Mul(c1a, c1b, k1a, k1b);
        (int c2a,int c2b) = fp2Conj(x2a, x2b, 64);
        (int d2a,int d2b) = fp2Mul(c2a, c2b, k2a, k2b);
        return d0a, d0b, d1a, d1b, d2a, d2b;
    }
    internal function fp6FrobEven(int x0a,int x0b,int x1a,int x1b,int x2a,int x2b, int k1a,int k1b,int k2a,int k2b) returns (int,int,int,int,int,int) {
        (int d1a,int d1b) = fp2Mul(x1a, x1b, k1a, k1b);
        (int d2a,int d2b) = fp2Mul(x2a, x2b, k2a, k2b);
        return x0a, x0b, d1a, d1b, d2a, d2b;
    }
    internal function fp6MulByFp2(int x0a,int x0b,int x1a,int x1b,int x2a,int x2b, int ka,int kb) returns (int,int,int,int,int,int) {
        (int r0a,int r0b) = fp2Mul(x0a, x0b, ka, kb);
        (int r1a,int r1b) = fp2Mul(x1a, x1b, ka, kb);
        (int r2a,int r2b) = fp2Mul(x2a, x2b, ka, kb);
        return r0a, r0b, r1a, r1b, r2a, r2b;
    }

    // ---- Fp12 ----
    internal function fp12Mul(
        int A0,int A1,int A2,int A3,int A4,int A5, int A6,int A7,int A8,int A9,int A10,int A11,
        int B0,int B1,int B2,int B3,int B4,int B5, int B6,int B7,int B8,int B9,int B10,int B11
    ) returns (int,int,int,int,int,int,int,int,int,int,int,int) {
        (int t0_0,int t0_1,int t0_2,int t0_3,int t0_4,int t0_5) = fp6Mul(A0,A1,A2,A3,A4,A5, B0,B1,B2,B3,B4,B5);
        (int t1_0,int t1_1,int t1_2,int t1_3,int t1_4,int t1_5) = fp6Mul(A6,A7,A8,A9,A10,A11, B6,B7,B8,B9,B10,B11);
        (int vt_0,int vt_1,int vt_2,int vt_3,int vt_4,int vt_5) = fp6MulByV(t1_0,t1_1,t1_2,t1_3,t1_4,t1_5, 12);
        (int C0,int C1,int C2,int C3,int C4,int C5) = fp6Add(t0_0,t0_1,t0_2,t0_3,t0_4,t0_5, vt_0,vt_1,vt_2,vt_3,vt_4,vt_5);
        (int sa_0,int sa_1,int sa_2,int sa_3,int sa_4,int sa_5) = fp6Add(A0,A1,A2,A3,A4,A5, A6,A7,A8,A9,A10,A11);
        (int sb_0,int sb_1,int sb_2,int sb_3,int sb_4,int sb_5) = fp6Add(B0,B1,B2,B3,B4,B5, B6,B7,B8,B9,B10,B11);
        (int pr_0,int pr_1,int pr_2,int pr_3,int pr_4,int pr_5) = fp6Mul(sa_0,sa_1,sa_2,sa_3,sa_4,sa_5, sb_0,sb_1,sb_2,sb_3,sb_4,sb_5);
        (int qq_0,int qq_1,int qq_2,int qq_3,int qq_4,int qq_5) = fp6Sub(pr_0,pr_1,pr_2,pr_3,pr_4,pr_5, t0_0,t0_1,t0_2,t0_3,t0_4,t0_5, 12);
        (int C6,int C7,int C8,int C9,int C10,int C11) = fp6Sub(qq_0,qq_1,qq_2,qq_3,qq_4,qq_5, t1_0,t1_1,t1_2,t1_3,t1_4,t1_5, 12);
        return C0,C1,C2,C3,C4,C5,C6,C7,C8,C9,C10,C11;
    }
    internal function fp12Conj(int A0,int A1,int A2,int A3,int A4,int A5, int A6,int A7,int A8,int A9,int A10,int A11)
        returns (int,int,int,int,int,int,int,int,int,int,int,int) {
        (int N6,int N7,int N8,int N9,int N10,int N11) = fp6Neg(A6,A7,A8,A9,A10,A11, 64);
        return A0,A1,A2,A3,A4,A5,N6,N7,N8,N9,N10,N11;
    }
    internal function fp12Inv(int A0,int A1,int A2,int A3,int A4,int A5, int A6,int A7,int A8,int A9,int A10,int A11)
        returns (int,int,int,int,int,int,int,int,int,int,int,int) {
        (int sc0_0,int sc0_1,int sc0_2,int sc0_3,int sc0_4,int sc0_5) = fp6Mul(A0,A1,A2,A3,A4,A5, A0,A1,A2,A3,A4,A5);
        (int sc1_0,int sc1_1,int sc1_2,int sc1_3,int sc1_4,int sc1_5) = fp6Mul(A6,A7,A8,A9,A10,A11, A6,A7,A8,A9,A10,A11);
        (int vc_0,int vc_1,int vc_2,int vc_3,int vc_4,int vc_5) = fp6MulByV(sc1_0,sc1_1,sc1_2,sc1_3,sc1_4,sc1_5, 12);
        (int dn_0,int dn_1,int dn_2,int dn_3,int dn_4,int dn_5) = fp6Sub(sc0_0,sc0_1,sc0_2,sc0_3,sc0_4,sc0_5, vc_0,vc_1,vc_2,vc_3,vc_4,vc_5, 13);
        (int t_0,int t_1,int t_2,int t_3,int t_4,int t_5) = fp6Inv(dn_0,dn_1,dn_2,dn_3,dn_4,dn_5);
        (int n0,int n1,int n2,int n3,int n4,int n5) = fp6Mul(A0,A1,A2,A3,A4,A5, t_0,t_1,t_2,t_3,t_4,t_5);
        (int u0,int u1,int u2,int u3,int u4,int u5) = fp6Mul(A6,A7,A8,A9,A10,A11, t_0,t_1,t_2,t_3,t_4,t_5);
        (int w0,int w1,int w2,int w3,int w4,int w5) = fp6Neg(u0,u1,u2,u3,u4,u5, 12);
        return n0,n1,n2,n3,n4,n5,w0,w1,w2,w3,w4,w5;
    }
    internal function fp12Frob1(int A0,int A1,int A2,int A3,int A4,int A5, int A6,int A7,int A8,int A9,int A10,int A11)
        returns (int,int,int,int,int,int,int,int,int,int,int,int) {
        (int c0,int c1,int c2,int c3,int c4,int c5) = fp6FrobOdd(A0,A1,A2,A3,A4,A5,
            21575463638280843010398324269430826099269044274347216827212613867836435027261, 10307601595873709700152284273816112264069230130616436755625194854815875713954,
            2581911344467009335267311115468803099551665605076196740867805258568234346338, 19937756971775647987995932169929341994314640652964949448313374472400716661030);
        (int g0,int g1,int g2,int g3,int g4,int g5) = fp6FrobOdd(A6,A7,A8,A9,A10,A11,
            21575463638280843010398324269430826099269044274347216827212613867836435027261, 10307601595873709700152284273816112264069230130616436755625194854815875713954,
            2581911344467009335267311115468803099551665605076196740867805258568234346338, 19937756971775647987995932169929341994314640652964949448313374472400716661030);
        (int f0,int f1,int f2,int f3,int f4,int f5) = fp6MulByFp2(g0,g1,g2,g3,g4,g5,
            8376118865763821496583973867626364092589906065868298776909617916018768340080, 16469823323077808223889137241176536799009286646108169935659301613961712198316);
        return c0,c1,c2,c3,c4,c5,f0,f1,f2,f3,f4,f5;
    }
    internal function fp12Frob2(int A0,int A1,int A2,int A3,int A4,int A5, int A6,int A7,int A8,int A9,int A10,int A11)
        returns (int,int,int,int,int,int,int,int,int,int,int,int) {
        (int c0,int c1,int c2,int c3,int c4,int c5) = fp6FrobEven(A0,A1,A2,A3,A4,A5,
            21888242871839275220042445260109153167277707414472061641714758635765020556616, 0,
            2203960485148121921418603742825762020974279258880205651966, 0);
        (int g0,int g1,int g2,int g3,int g4,int g5) = fp6FrobEven(A6,A7,A8,A9,A10,A11,
            21888242871839275220042445260109153167277707414472061641714758635765020556616, 0,
            2203960485148121921418603742825762020974279258880205651966, 0);
        (int f0,int f1,int f2,int f3,int f4,int f5) = fp6MulByFp2(g0,g1,g2,g3,g4,g5,
            21888242871839275220042445260109153167277707414472061641714758635765020556617, 0);
        return c0,c1,c2,c3,c4,c5,f0,f1,f2,f3,f4,f5;
    }
    internal function fp12Frob3(int A0,int A1,int A2,int A3,int A4,int A5, int A6,int A7,int A8,int A9,int A10,int A11)
        returns (int,int,int,int,int,int,int,int,int,int,int,int) {
        (int c0,int c1,int c2,int c3,int c4,int c5) = fp6FrobOdd(A0,A1,A2,A3,A4,A5,
            3772000881919853776433695186713858239009073593817195771773381919316419345261, 2236595495967245188281701248203181795121068902605861227855261137820944008926,
            5324479202449903542726783395506214481928257762400643279780343368557297135718, 16208900380737693084919495127334387981393726419856888799917914180988844123039);
        (int g0,int g1,int g2,int g3,int g4,int g5) = fp6FrobOdd(A6,A7,A8,A9,A10,A11,
            3772000881919853776433695186713858239009073593817195771773381919316419345261, 2236595495967245188281701248203181795121068902605861227855261137820944008926,
            5324479202449903542726783395506214481928257762400643279780343368557297135718, 16208900380737693084919495127334387981393726419856888799917914180988844123039);
        (int f0,int f1,int f2,int f3,int f4,int f5) = fp6MulByFp2(g0,g1,g2,g3,g4,g5,
            11697423496358154304825782922584725312912383441159505038794027105778954184319, 303847389135065887422783454877609941456349188919719272345083954437860409601);
        return c0,c1,c2,c3,c4,c5,f0,f1,f2,f3,f4,f5;
    }
    // cyclotomic squaring (noble _cyclotomicSquare via Fp4Square)
    internal function fp4Square(int a0,int a1,int b0,int b1) returns (int,int,int,int) {
        (int a2a,int a2b) = fp2Sqr(a0, a1);
        (int b2a,int b2b) = fp2Sqr(b0, b1);
        (int xbi0,int xbi1) = fp2MulXi(b2a, b2b, 1);
        (int f0,int f1) = fp2Add(xbi0, xbi1, a2a, a2b);
        (int aba,int abb) = fp2Add(a0, a1, b0, b1);
        (int absqa,int absqb) = fp2Sqr(aba, abb);
        (int sub1a,int sub1b) = fp2Sub(absqa, absqb, a2a, a2b, 1);
        (int s0,int s1) = fp2Sub(sub1a, sub1b, b2a, b2b, 1);
        return f0, f1, s0, s1;
    }
    internal function cycSqr(int A0,int A1,int A2,int A3,int A4,int A5, int A6,int A7,int A8,int A9,int A10,int A11)
        returns (int,int,int,int,int,int,int,int,int,int,int,int) {
        // c0c0=A0A1 c0c1=A2A3 c0c2=A4A5  c1c0=A6A7 c1c1=A8A9 c1c2=A10A11
        (int t3a,int t3b,int t4a,int t4b) = fp4Square(A0,A1, A8,A9);
        (int t5a,int t5b,int t6a,int t6b) = fp4Square(A6,A7, A4,A5);
        (int t7a,int t7b,int t8a,int t8b) = fp4Square(A2,A3, A10,A11);
        (int t9a,int t9b) = fp2MulXi(t8a, t8b, 3);
        // out c0ci = 2*(Ti - c0ci) + Ti ; out c1ci = 2*(Ti + c1ci) + Ti
        // z0/z1/z2 subtract the carried input A (bound <=37); 64p bias, mul-consumed by mulFp(z,2)
        (int z0a,int z0b) = fp2Sub(t3a, t3b, A0, A1, 64);   (int o0a,int o0b) = fp2Add(mulFp(z0a,2), mulFp(z0b,2), t3a, t3b);
        (int z1a,int z1b) = fp2Sub(t5a, t5b, A2, A3, 64);   (int o1a,int o1b) = fp2Add(mulFp(z1a,2), mulFp(z1b,2), t5a, t5b);
        (int z2a,int z2b) = fp2Sub(t7a, t7b, A4, A5, 64);   (int o2a,int o2b) = fp2Add(mulFp(z2a,2), mulFp(z2b,2), t7a, t7b);
        (int z3a,int z3b) = fp2Add(t9a, t9b, A6, A7);   (int o3a,int o3b) = fp2Add(mulFp(z3a,2), mulFp(z3b,2), t9a, t9b);
        (int z4a,int z4b) = fp2Add(t4a, t4b, A8, A9);   (int o4a,int o4b) = fp2Add(mulFp(z4a,2), mulFp(z4b,2), t4a, t4b);
        (int z5a,int z5b) = fp2Add(t6a, t6b, A10, A11); (int o5a,int o5b) = fp2Add(mulFp(z5a,2), mulFp(z5b,2), t6a, t6b);
        return o0a,o0b,o1a,o1b,o2a,o2b,o3a,o3b,o4a,o4b,o5a,o5b;
    }
    // cyclotomicExp(num, BN_X) — square-and-multiply over the 63 bits of X (MSB-first)
    internal function cycExpX(int N0,int N1,int N2,int N3,int N4,int N5,int N6,int N7,int N8,int N9,int N10,int N11)
        returns (int,int,int,int,int,int,int,int,int,int,int,int) {
        int Z0=1; int Z1=0; int Z2=0; int Z3=0; int Z4=0; int Z5=0; int Z6=0; int Z7=0; int Z8=0; int Z9=0; int Z10=0; int Z11=0;
        for (int k = 0; k < 63; k = k + 1) {
            int i = 62 - k;
            (int s0,int s1,int s2,int s3,int s4,int s5,int s6,int s7,int s8,int s9,int s10,int s11) =
                cycSqr(Z0,Z1,Z2,Z3,Z4,Z5,Z6,Z7,Z8,Z9,Z10,Z11);
            Z0=s0; Z1=s1; Z2=s2; Z3=s3; Z4=s4; Z5=s5; Z6=s6; Z7=s7; Z8=s8; Z9=s9; Z10=s10; Z11=s11;
            if (((4965661367192848881 >> i) % 2) == 1) {
                (int m0,int m1,int m2,int m3,int m4,int m5,int m6,int m7,int m8,int m9,int m10,int m11) =
                    fp12Mul(Z0,Z1,Z2,Z3,Z4,Z5,Z6,Z7,Z8,Z9,Z10,Z11, N0,N1,N2,N3,N4,N5,N6,N7,N8,N9,N10,N11);
                Z0=m0; Z1=m1; Z2=m2; Z3=m3; Z4=m4; Z5=m5; Z6=m6; Z7=m7; Z8=m8; Z9=m9; Z10=m10; Z11=m11;
            }
        }
        return Z0,Z1,Z2,Z3,Z4,Z5,Z6,Z7,Z8,Z9,Z10,Z11;
    }
    // powMinusX = conj(cycExpX(num))   (X is the positive BN seed; conj for the negation)
    internal function powMinusX(int N0,int N1,int N2,int N3,int N4,int N5,int N6,int N7,int N8,int N9,int N10,int N11)
        returns (int,int,int,int,int,int,int,int,int,int,int,int) {
        (int p0,int p1,int p2,int p3,int p4,int p5,int p6,int p7,int p8,int p9,int p10,int p11) =
            cycExpX(N0,N1,N2,N3,N4,N5,N6,N7,N8,N9,N10,N11);
        (int c0,int c1,int c2,int c3,int c4,int c5,int c6,int c7,int c8,int c9,int c10,int c11) =
            fp12Conj(p0,p1,p2,p3,p4,p5,p6,p7,p8,p9,p10,p11);
        return c0,c1,c2,c3,c4,c5,c6,c7,c8,c9,c10,c11;
    }

    internal function finalExp(int A0,int A1,int A2,int A3,int A4,int A5,int A6,int A7,int A8,int A9,int A10,int A11)
        returns (int,int,int,int,int,int,int,int,int,int,int,int) {
        // easy part: r0 = conj(f) * inv(f)
        (int cn0,int cn1,int cn2,int cn3,int cn4,int cn5,int cn6,int cn7,int cn8,int cn9,int cn10,int cn11) =
            fp12Conj(A0,A1,A2,A3,A4,A5,A6,A7,A8,A9,A10,A11);
        (int iv0,int iv1,int iv2,int iv3,int iv4,int iv5,int iv6,int iv7,int iv8,int iv9,int iv10,int iv11) =
            fp12Inv(A0,A1,A2,A3,A4,A5,A6,A7,A8,A9,A10,A11);
        (int r0a,int r0b,int r0c,int r0d,int r0e,int r0f,int r0g,int r0h,int r0i,int r0j,int r0k,int r0l) =
            fp12Mul(cn0,cn1,cn2,cn3,cn4,cn5,cn6,cn7,cn8,cn9,cn10,cn11, iv0,iv1,iv2,iv3,iv4,iv5,iv6,iv7,iv8,iv9,iv10,iv11);
        // r = frob2(r0) * r0
        (int fr0,int fr1,int fr2,int fr3,int fr4,int fr5,int fr6,int fr7,int fr8,int fr9,int fr10,int fr11) =
            fp12Frob2(r0a,r0b,r0c,r0d,r0e,r0f,r0g,r0h,r0i,r0j,r0k,r0l);
        (int R0,int R1,int R2,int R3,int R4,int R5,int R6,int R7,int R8,int R9,int R10,int R11) =
            fp12Mul(fr0,fr1,fr2,fr3,fr4,fr5,fr6,fr7,fr8,fr9,fr10,fr11, r0a,r0b,r0c,r0d,r0e,r0f,r0g,r0h,r0i,r0j,r0k,r0l);
        // hard part
        (int pm0,int pm1,int pm2,int pm3,int pm4,int pm5,int pm6,int pm7,int pm8,int pm9,int pm10,int pm11) =
            powMinusX(R0,R1,R2,R3,R4,R5,R6,R7,R8,R9,R10,R11);
        (int y10,int y11_,int y12,int y13,int y14,int y15,int y16,int y17,int y18,int y19,int y1a,int y1b) =
            cycSqr(pm0,pm1,pm2,pm3,pm4,pm5,pm6,pm7,pm8,pm9,pm10,pm11);
        (int cy10,int cy11,int cy12,int cy13,int cy14,int cy15,int cy16,int cy17,int cy18,int cy19,int cy1a,int cy1b) =
            cycSqr(y10,y11_,y12,y13,y14,y15,y16,y17,y18,y19,y1a,y1b);
        (int y20,int y21,int y22,int y23,int y24,int y25,int y26,int y27,int y28,int y29,int y2a,int y2b) =
            fp12Mul(cy10,cy11,cy12,cy13,cy14,cy15,cy16,cy17,cy18,cy19,cy1a,cy1b, y10,y11_,y12,y13,y14,y15,y16,y17,y18,y19,y1a,y1b);
        (int y40,int y41,int y42,int y43,int y44,int y45,int y46,int y47,int y48,int y49,int y4a,int y4b) =
            powMinusX(y20,y21,y22,y23,y24,y25,y26,y27,y28,y29,y2a,y2b);
        (int cy40,int cy41,int cy42,int cy43,int cy44,int cy45,int cy46,int cy47,int cy48,int cy49,int cy4a,int cy4b) =
            cycSqr(y40,y41,y42,y43,y44,y45,y46,y47,y48,y49,y4a,y4b);
        (int y60,int y61,int y62,int y63,int y64,int y65,int y66,int y67,int y68,int y69,int y6a,int y6b) =
            powMinusX(cy40,cy41,cy42,cy43,cy44,cy45,cy46,cy47,cy48,cy49,cy4a,cy4b);
        // y8 = conj(y6)*y4*conj(y2)
        (int ny60,int ny61,int ny62,int ny63,int ny64,int ny65,int ny66,int ny67,int ny68,int ny69,int ny6a,int ny6b) =
            fp12Conj(y60,y61,y62,y63,y64,y65,y66,y67,y68,y69,y6a,y6b);
        (int t8a,int t8b,int t8c,int t8d,int t8e,int t8f,int t8g,int t8h,int t8i,int t8j,int t8k,int t8l) =
            fp12Mul(ny60,ny61,ny62,ny63,ny64,ny65,ny66,ny67,ny68,ny69,ny6a,ny6b, y40,y41,y42,y43,y44,y45,y46,y47,y48,y49,y4a,y4b);
        (int ny20,int ny21,int ny22,int ny23,int ny24,int ny25,int ny26,int ny27,int ny28,int ny29,int ny2a,int ny2b) =
            fp12Conj(y20,y21,y22,y23,y24,y25,y26,y27,y28,y29,y2a,y2b);
        (int y80,int y81,int y82,int y83,int y84,int y85,int y86,int y87,int y88,int y89,int y8a,int y8b) =
            fp12Mul(t8a,t8b,t8c,t8d,t8e,t8f,t8g,t8h,t8i,t8j,t8k,t8l, ny20,ny21,ny22,ny23,ny24,ny25,ny26,ny27,ny28,ny29,ny2a,ny2b);
        // y9 = y8*y1
        (int y90,int y91,int y92,int y93,int y94,int y95,int y96,int y97,int y98,int y99,int y9a,int y9b) =
            fp12Mul(y80,y81,y82,y83,y84,y85,y86,y87,y88,y89,y8a,y8b, y10,y11_,y12,y13,y14,y15,y16,y17,y18,y19,y1a,y1b);
        // left = frob3(conj(r)*y9)
        (int cr0,int cr1,int cr2,int cr3,int cr4,int cr5,int cr6,int cr7,int cr8,int cr9,int cra,int crb) =
            fp12Conj(R0,R1,R2,R3,R4,R5,R6,R7,R8,R9,R10,R11);
        (int cry90,int cry91,int cry92,int cry93,int cry94,int cry95,int cry96,int cry97,int cry98,int cry99,int cry9a,int cry9b) =
            fp12Mul(cr0,cr1,cr2,cr3,cr4,cr5,cr6,cr7,cr8,cr9,cra,crb, y90,y91,y92,y93,y94,y95,y96,y97,y98,y99,y9a,y9b);
        (int L0,int L1,int L2,int L3,int L4,int L5,int L6,int L7,int L8,int L9,int La,int Lb) =
            fp12Frob3(cry90,cry91,cry92,cry93,cry94,cry95,cry96,cry97,cry98,cry99,cry9a,cry9b);
        // right = frob2(y8) * ( frob1(y9) * ((y8*y4)*r) )
        (int f2y80,int f2y81,int f2y82,int f2y83,int f2y84,int f2y85,int f2y86,int f2y87,int f2y88,int f2y89,int f2y8a,int f2y8b) =
            fp12Frob2(y80,y81,y82,y83,y84,y85,y86,y87,y88,y89,y8a,y8b);
        (int f1y90,int f1y91,int f1y92,int f1y93,int f1y94,int f1y95,int f1y96,int f1y97,int f1y98,int f1y99,int f1y9a,int f1y9b) =
            fp12Frob1(y90,y91,y92,y93,y94,y95,y96,y97,y98,y99,y9a,y9b);
        (int y8y40,int y8y41,int y8y42,int y8y43,int y8y44,int y8y45,int y8y46,int y8y47,int y8y48,int y8y49,int y8y4a,int y8y4b) =
            fp12Mul(y80,y81,y82,y83,y84,y85,y86,y87,y88,y89,y8a,y8b, y40,y41,y42,y43,y44,y45,y46,y47,y48,y49,y4a,y4b);
        (int y8y4r0,int y8y4r1,int y8y4r2,int y8y4r3,int y8y4r4,int y8y4r5,int y8y4r6,int y8y4r7,int y8y4r8,int y8y4r9,int y8y4ra,int y8y4rb) =
            fp12Mul(y8y40,y8y41,y8y42,y8y43,y8y44,y8y45,y8y46,y8y47,y8y48,y8y49,y8y4a,y8y4b, R0,R1,R2,R3,R4,R5,R6,R7,R8,R9,R10,R11);
        (int inn0,int inn1,int inn2,int inn3,int inn4,int inn5,int inn6,int inn7,int inn8,int inn9,int inna,int innb) =
            fp12Mul(f1y90,f1y91,f1y92,f1y93,f1y94,f1y95,f1y96,f1y97,f1y98,f1y99,f1y9a,f1y9b, y8y4r0,y8y4r1,y8y4r2,y8y4r3,y8y4r4,y8y4r5,y8y4r6,y8y4r7,y8y4r8,y8y4r9,y8y4ra,y8y4rb);
        (int RT0,int RT1,int RT2,int RT3,int RT4,int RT5,int RT6,int RT7,int RT8,int RT9,int RTa,int RTb) =
            fp12Mul(f2y80,f2y81,f2y82,f2y83,f2y84,f2y85,f2y86,f2y87,f2y88,f2y89,f2y8a,f2y8b, inn0,inn1,inn2,inn3,inn4,inn5,inn6,inn7,inn8,inn9,inna,innb);
        // result = left * right
        (int O0,int O1,int O2,int O3,int O4,int O5,int O6,int O7,int O8,int O9,int O10,int O11) =
            fp12Mul(L0,L1,L2,L3,L4,L5,L6,L7,L8,L9,La,Lb, RT0,RT1,RT2,RT3,RT4,RT5,RT6,RT7,RT8,RT9,RTa,RTb);
        return O0,O1,O2,O3,O4,O5,O6,O7,O8,O9,O10,O11;
    }

    function spend(
        int A0,int A1,int A2,int A3,int A4,int A5,int A6,int A7,int A8,int A9,int A10,int A11,
        int M0,int M1,int M2,int M3,int M4,int M5,int M6,int M7,int M8,int M9,int M10,int M11
    ) {
        (int o0,int o1,int o2,int o3,int o4,int o5,int o6,int o7,int o8,int o9,int o10,int o11) =
            finalExp(A0,A1,A2,A3,A4,A5,A6,A7,A8,A9,A10,A11);
        // reduce the lazy result to canonical [0,p) before comparing to noble
        int P = 21888242871839275222246405745257275088696311157297823662689037894645226208583;
        require(o0 % P==M0); require(o1 % P==M1); require(o2 % P==M2); require(o3 % P==M3); require(o4 % P==M4); require(o5 % P==M5);
        require(o6 % P==M6); require(o7 % P==M7); require(o8 % P==M8); require(o9 % P==M9); require(o10 % P==M10); require(o11 % P==M11);
    }
}
