pragma cashscript ^0.14.0;

// BN254 base field Fp over the prime p (written out literally at each use site --
// the compiler folds it, and top-level constants are not part of the language).
// Consumed via `import "./lib/Fp.cash";` which brings these top-level functions
// into the importing file's scope unqualified (addFp, mulFp, ...).

function addFp(int x, int y) returns (int) { return (x + y) % 21888242871839275222246405745257275088696311157297823662689037894645226208583; }
function subFp(int x, int y) returns (int) { return (x - y + 21888242871839275222246405745257275088696311157297823662689037894645226208583) % 21888242871839275222246405745257275088696311157297823662689037894645226208583; }
function mulFp(int x, int y) returns (int) { return (x * y) % 21888242871839275222246405745257275088696311157297823662689037894645226208583; }
function sqrFp(int x) returns (int) { return (x * x) % 21888242871839275222246405745257275088696311157297823662689037894645226208583; }
function negFp(int x) returns (int) { return (21888242871839275222246405745257275088696311157297823662689037894645226208583 - x) % 21888242871839275222246405745257275088696311157297823662689037894645226208583; }

// Fermat inverse x^(p-2) mod p over the 254 bits of (p-2). The prime is bound to a local `p` (as
// in the hand-written sources) so the 254-iteration loop reuses one stack slot rather than
// re-pushing the 32-byte literal each iteration.
function inverseFp(int x) returns (int) {
    int p = 21888242871839275222246405745257275088696311157297823662689037894645226208583;
    int e = p - 2;
    int result = 1;
    int current = x % p;
    for (int i = 0; i < 254; i = i + 1) {
        if (((e >> i) % 2) == 1) { result = (result * current) % p; }
        current = (current * current) % p;
    }
    return result;
}
