pragma cashscript ^0.14.0;

// BN254 LAZY-arithmetic shared functions (option B: addFp/subFp do NOT reduce; subFp carries a per-call-site
// k*p bias; only mulFp reduces). Serves the two lazy-scheme harnesses miller.cash and finalexp.cash.
// One file holds the union of both; dead-code elimination drops the half a given consumer does not call.
function addFp(int x, int y) returns (int) { return x + y; }

function subFp(int x, int y, int k) returns (int) { return x - y + k * 21888242871839275222246405745257275088696311157297823662689037894645226208583; }

function mulFp(int x, int y) returns (int) { return (x * y) % 21888242871839275222246405745257275088696311157297823662689037894645226208583; }

function fp2Add(int a0, int a1, int b0, int b1) returns (int, int) { return addFp(a0, b0), addFp(a1, b1); }

function fp2Sub(int a0, int a1, int b0, int b1, int k) returns (int, int) { return subFp(a0, b0, k), subFp(a1, b1, k); }

function fp2Neg(int a0, int a1, int k) returns (int, int) { return subFp(0, a0, k), subFp(0, a1, k); }

function fp2Mul(int a0, int a1, int b0, int b1) returns (int, int) {
        // bound_analysis.mjs proves every operand is nonnegative and < 149*p without relying on
        // this function's canonical output. Thus v0-v1 > -149^2*p^2, while the second Karatsuba
        // limb expands to a0*b1+a1*b0 and is already nonnegative. 22,201*p^2 is a multiple of p.
        int v0 = a0 * b0;
        int v1 = a1 * b1;
        int p = 21888242871839275222246405745257275088696311157297823662689037894645226208583;
        int nonnegativeBias = 10636392002745043725054576591855484724484200679306969358911577657842610149931283249579519191443340195632349945621165638913026711333532969846898571500690003689;
        return (v0 - v1 + nonnegativeBias) % p,
               ((a0 + a1) * (b0 + b1) - v0 - v1) % p;
    }

function fp2MulRaw(int a0, int a1, int b0, int b1) returns (int, int) {
        // Unreduced Karatsuba product, consumed only inside mul034, fp12Mul, and fp12Sqr before
        // their final normalization.
        int v0 = a0 * b0;
        int v1 = a1 * b1;
        return v0 - v1, (a0 + a1) * (b0 + b1) - v0 - v1;
    }

// One field reduction followed by sign normalization. Script remainder is in
// (-p,p), so the conditional add maps it canonically into [0,p) without a second
// modulo operation.
function canonicalFp(int x) returns (int) {
        int p = 21888242871839275222246405745257275088696311157297823662689037894645226208583;
        int r = x % p;
        if (r < 0) { r = r + p; }
        return r;
    }

function signedFp(int x) returns (int) {
        return x % 21888242871839275222246405745257275088696311157297823662689037894645226208583;
    }

function fp2Sqr(int a0, int a1) returns (int, int) {
        // Global lazy bound is <36p, so (2*a0)*a1 is <2592p^2 before the one reduction.
        return mulFp(addFp(a0, a1), subFp(a0, a1, 64)), mulFp(a0 + a0, a1);
    }

function fp2Scale(int a0, int a1, int k) returns (int, int) { return mulFp(a0, k), mulFp(a1, k); }

function fp2MulXi(int a0, int a1, int k) returns (int, int) { return subFp(mulFp(9, a0), a1, k), addFp(mulFp(9, a1), a0); }

function fp2Conj(int a0, int a1, int k) returns (int, int) { return a0, subFp(0, a1, k); }

function fp2MulByB(int a0, int a1) returns (int, int) {
        (int r0, int r1) = fp2Mul(a0, a1,
            19485874751759354771024239261021720505790618469301721065564631296452457478373,
            266929791119991161246907387137283842545076965332900288569378510910307636690);
        return r0, r1;
    }

function fp2Half(int a0, int a1) returns (int, int) {
        return mulFp(a0, 10944121435919637611123202872628637544348155578648911831344518947322613104292),
               mulFp(a1, 10944121435919637611123202872628637544348155578648911831344518947322613104292);
    }

function fp6Add(int a0a,int a0b,int a1a,int a1b,int a2a,int a2b,int b0a,int b0b,int b1a,int b1b,int b2a,int b2b) returns (int,int,int,int,int,int) {
        (int c0a, int c0b) = fp2Add(a0a, a0b, b0a, b0b);
        (int c1a, int c1b) = fp2Add(a1a, a1b, b1a, b1b);
        (int c2a, int c2b) = fp2Add(a2a, a2b, b2a, b2b);
        return c0a, c0b, c1a, c1b, c2a, c2b;
    }

function fp6Sub(int a0a,int a0b,int a1a,int a1b,int a2a,int a2b,int b0a,int b0b,int b1a,int b1b,int b2a,int b2b, int k) returns (int,int,int,int,int,int) {
        (int c0a, int c0b) = fp2Sub(a0a, a0b, b0a, b0b, k);
        (int c1a, int c1b) = fp2Sub(a1a, a1b, b1a, b1b, k);
        (int c2a, int c2b) = fp2Sub(a2a, a2b, b2a, b2b, k);
        return c0a, c0b, c1a, c1b, c2a, c2b;
    }

function fp6MulByV(int a0a,int a0b,int a1a,int a1b,int a2a,int a2b, int k) returns (int,int,int,int,int,int) {
        (int n0a, int n0b) = fp2MulXi(a2a, a2b, k);
        return n0a, n0b, a0a, a0b, a1a, a1b;
    }

function fp6Mul(int a0a,int a0b,int a1a,int a1b,int a2a,int a2b,int b0a,int b0b,int b1a,int b1b,int b2a,int b2b) returns (int,int,int,int,int,int) {
        (int t0a, int t0b) = fp2Mul(a0a, a0b, b0a, b0b);
        (int t1a, int t1b) = fp2Mul(a1a, a1b, b1a, b1b);
        (int t2a, int t2b) = fp2Mul(a2a, a2b, b2a, b2b);
        (int s1a, int s1b) = fp2Add(a1a, a1b, a2a, a2b);
        (int s2a, int s2b) = fp2Add(b1a, b1b, b2a, b2b);
        (int p1a, int p1b) = fp2Mul(s1a, s1b, s2a, s2b);
        (int d1a, int d1b) = fp2Sub(p1a, p1b, t1a, t1b, 3);
        (int d2a, int d2b) = fp2Sub(d1a, d1b, t2a, t2b, 3);
        (int x1a, int x1b) = fp2MulXi(d2a, d2b, 9);
        (int c0a, int c0b) = fp2Add(t0a, t0b, x1a, x1b);
        (int s3a, int s3b) = fp2Add(a0a, a0b, a1a, a1b);
        (int s4a, int s4b) = fp2Add(b0a, b0b, b1a, b1b);
        (int p2a, int p2b) = fp2Mul(s3a, s3b, s4a, s4b);
        (int d3a, int d3b) = fp2Sub(p2a, p2b, t0a, t0b, 3);
        (int d4a, int d4b) = fp2Sub(d3a, d3b, t1a, t1b, 3);
        (int x2a, int x2b) = fp2MulXi(t2a, t2b, 3);
        (int c1a, int c1b) = fp2Add(d4a, d4b, x2a, x2b);
        (int s5a, int s5b) = fp2Add(a0a, a0b, a2a, a2b);
        (int s6a, int s6b) = fp2Add(b0a, b0b, b2a, b2b);
        (int p3a, int p3b) = fp2Mul(s5a, s5b, s6a, s6b);
        (int d5a, int d5b) = fp2Sub(p3a, p3b, t0a, t0b, 3);
        (int d6a, int d6b) = fp2Sub(d5a, d5b, t2a, t2b, 3);
        (int c2a, int c2b) = fp2Add(d6a, d6b, t1a, t1b);
        return c0a, c0b, c1a, c1b, c2a, c2b;
    }

function fp6MulRaw(int a0a,int a0b,int a1a,int a1b,int a2a,int a2b,int b0a,int b0b,int b1a,int b1b,int b2a,int b2b) returns (int,int,int,int,int,int) {
        (int t0a, int t0b) = fp2MulRaw(a0a, a0b, b0a, b0b);
        (int t1a, int t1b) = fp2MulRaw(a1a, a1b, b1a, b1b);
        (int t2a, int t2b) = fp2MulRaw(a2a, a2b, b2a, b2b);

        (int p1a, int p1b) = fp2MulRaw(a1a + a2a, a1b + a2b, b1a + b2a, b1b + b2b);
        int d2a = p1a - t1a - t2a;
        int d2b = p1b - t1b - t2b;
        int c0a = t0a + 9*d2a - d2b;
        int c0b = t0b + d2a + 9*d2b;

        (int p2a, int p2b) = fp2MulRaw(a0a + a1a, a0b + a1b, b0a + b1a, b0b + b1b);
        int d4a = p2a - t0a - t1a;
        int d4b = p2b - t0b - t1b;
        int c1a = d4a + 9*t2a - t2b;
        int c1b = d4b + t2a + 9*t2b;

        (int p3a, int p3b) = fp2MulRaw(a0a + a2a, a0b + a2b, b0a + b2a, b0b + b2b);
        int c2a = p3a - t0a - t2a + t1a;
        int c2b = p3b - t0b - t2b + t1b;
        return c0a, c0b, c1a, c1b, c2a, c2b;
    }

function fp6Mul01(int c0a,int c0b,int c1a,int c1b,int c2a,int c2b, int b0a,int b0b,int b1a,int b1b) returns (int,int,int,int,int,int) {
        (int t0a,int t0b) = fp2Mul(c0a, c0b, b0a, b0b);
        (int t1a,int t1b) = fp2Mul(c1a, c1b, b1a, b1b);
        (int s12a,int s12b) = fp2Add(c1a, c1b, c2a, c2b);
        (int m12a,int m12b) = fp2Mul(s12a, s12b, b1a, b1b);
        (int u0a,int u0b) = fp2Sub(m12a, m12b, t1a, t1b, 3);
        (int xu0a,int xu0b) = fp2MulXi(u0a, u0b, 6);
        (int r0a,int r0b) = fp2Add(xu0a, xu0b, t0a, t0b);
        (int sba,int sbb) = fp2Add(b0a, b0b, b1a, b1b);
        (int sca,int scb) = fp2Add(c0a, c0b, c1a, c1b);
        (int m1a,int m1b) = fp2Mul(sba, sbb, sca, scb);
        (int u1a,int u1b) = fp2Sub(m1a, m1b, t0a, t0b, 3);
        (int r1a,int r1b) = fp2Sub(u1a, u1b, t1a, t1b, 3);
        (int s02a,int s02b) = fp2Add(c0a, c0b, c2a, c2b);
        (int m2a,int m2b) = fp2Mul(s02a, s02b, b0a, b0b);
        (int u2a,int u2b) = fp2Sub(m2a, m2b, t0a, t0b, 3);
        (int r2a,int r2b) = fp2Add(u2a, u2b, t1a, t1b);
        return r0a, r0b, r1a, r1b, r2a, r2b;
    }

function fp12Mul(
        int A0,int A1,int A2,int A3,int A4,int A5, int A6,int A7,int A8,int A9,int A10,int A11,
        int B0,int B1,int B2,int B3,int B4,int B5, int B6,int B7,int B8,int B9,int B10,int B11
    ) returns (int,int,int,int,int,int,int,int,int,int,int,int) {
        // Tower Karatsuba over Z: c0=a0*b0+v*a1*b1 and
        // c1=(a0+a1)*(b0+b1)-a0*b0-a1*b1. The three Fp6 products remain
        // unreduced until the final twelve limbs.
        (int t0_0,int t0_1,int t0_2,int t0_3,int t0_4,int t0_5) =
            fp6MulRaw(A0,A1,A2,A3,A4,A5, B0,B1,B2,B3,B4,B5);
        (int t1_0,int t1_1,int t1_2,int t1_3,int t1_4,int t1_5) =
            fp6MulRaw(A6,A7,A8,A9,A10,A11, B6,B7,B8,B9,B10,B11);
        (int pr_0,int pr_1,int pr_2,int pr_3,int pr_4,int pr_5) =
            fp6MulRaw(A0+A6,A1+A7,A2+A8,A3+A9,A4+A10,A5+A11,
                      B0+B6,B1+B7,B2+B8,B3+B9,B4+B10,B5+B11);

        int C0 = canonicalFp(t0_0 + 9*t1_4 - t1_5);
        int C1 = canonicalFp(t0_1 + t1_4 + 9*t1_5);
        int C2 = canonicalFp(t0_2 + t1_0);
        int C3 = canonicalFp(t0_3 + t1_1);
        int C4 = canonicalFp(t0_4 + t1_2);
        int C5 = canonicalFp(t0_5 + t1_3);
        int C6 = canonicalFp(pr_0 - t0_0 - t1_0);
        int C7 = canonicalFp(pr_1 - t0_1 - t1_1);
        int C8 = canonicalFp(pr_2 - t0_2 - t1_2);
        int C9 = canonicalFp(pr_3 - t0_3 - t1_3);
        int C10 = canonicalFp(pr_4 - t0_4 - t1_4);
        int C11 = canonicalFp(pr_5 - t0_5 - t1_5);
        return C0,C1,C2,C3,C4,C5,C6,C7,C8,C9,C10,C11;
    }

// Signed square used only by the chunked residue Miller hot path. Its outputs
// are field-equivalent representatives in (-p,p); callers must not serialize
// them before canonicalizing at the transaction seam.
function fp12SqrSigned(
        int A0,int A1,int A2,int A3,int A4,int A5, int A6,int A7,int A8,int A9,int A10,int A11
    ) returns (int,int,int,int,int,int,int,int,int,int,int,int) {
        // Exact tower identity over Z:
        //   t0=c0*c1; t1=(c0+c1)*(c0+v*c1)
        //   square=(t1-t0-v*t0, 2*t0).
        // Each Fp2 product uses three raw integer multiplies. No component is reduced
        // until the final twelve limbs, so this square performs exactly twelve mod-p
        // reductions instead of reducing every base-field product.

        // t0 = c0*c1, expanded through the Fp6 Karatsuba formula without reduction.
        (int t00a,int t00b) = fp2MulRaw(A0,A1, A6,A7);
        (int t01a,int t01b) = fp2MulRaw(A2,A3, A8,A9);
        (int t02a,int t02b) = fp2MulRaw(A4,A5, A10,A11);
        (int t0p1a,int t0p1b) = fp2MulRaw(A2+A4,A3+A5, A8+A10,A9+A11);
        int t0d2a = t0p1a - t01a - t02a;
        int t0d2b = t0p1b - t01b - t02b;
        int t0c0a = t00a + 9*t0d2a - t0d2b;
        int t0c0b = t00b + t0d2a + 9*t0d2b;
        (int t0p2a,int t0p2b) = fp2MulRaw(A0+A2,A1+A3, A6+A8,A7+A9);
        int t0d4a = t0p2a - t00a - t01a;
        int t0d4b = t0p2b - t00b - t01b;
        int t0c1a = t0d4a + 9*t02a - t02b;
        int t0c1b = t0d4b + t02a + 9*t02b;
        (int t0p3a,int t0p3b) = fp2MulRaw(A0+A4,A1+A5, A6+A10,A7+A11);
        int t0c2a = t0p3a - t00a - t02a + t01a;
        int t0c2b = t0p3b - t00b - t02b + t01b;

        // t1 = (c0+c1)*(c0+v*c1). Multiplication by v maps
        // (y0,y1,y2) to (xi*y2,y0,y1), xi=9+i, using only linear operations.
        int s0=A0+A6; int s1=A1+A7; int s2=A2+A8;
        int s3=A3+A9; int s4=A4+A10; int s5=A5+A11;
        int u0=A0+9*A10-A11; int u1=A1+A10+9*A11;
        int u2=A2+A6; int u3=A3+A7; int u4=A4+A8; int u5=A5+A9;
        (int t10a,int t10b) = fp2MulRaw(s0,s1, u0,u1);
        (int t11a,int t11b) = fp2MulRaw(s2,s3, u2,u3);
        (int t12a,int t12b) = fp2MulRaw(s4,s5, u4,u5);
        (int t1p1a,int t1p1b) = fp2MulRaw(s2+s4,s3+s5, u2+u4,u3+u5);
        int t1d2a = t1p1a - t11a - t12a;
        int t1d2b = t1p1b - t11b - t12b;
        int t1c0a = t10a + 9*t1d2a - t1d2b;
        int t1c0b = t10b + t1d2a + 9*t1d2b;
        (int t1p2a,int t1p2b) = fp2MulRaw(s0+s2,s1+s3, u0+u2,u1+u3);
        int t1d4a = t1p2a - t10a - t11a;
        int t1d4b = t1p2b - t10b - t11b;
        int t1c1a = t1d4a + 9*t12a - t12b;
        int t1c1b = t1d4b + t12a + 9*t12b;
        (int t1p3a,int t1p3b) = fp2MulRaw(s0+s4,s1+s5, u0+u4,u1+u5);
        int t1c2a = t1p3a - t10a - t12a + t11a;
        int t1c2b = t1p3b - t10b - t12b + t11b;

        // Keep the hot-path representative in (-p,p). Each chunk canonicalizes
        // its twelve outgoing limbs once at the transaction seam.
        int p = 21888242871839275222246405745257275088696311157297823662689037894645226208583;
        int C0 = (t1c0a - t0c0a - (9*t0c2a - t0c2b)) % p;
        int C1 = (t1c0b - t0c0b - (t0c2a + 9*t0c2b)) % p;
        int C2 = (t1c1a - t0c1a - t0c0a) % p;
        int C3 = (t1c1b - t0c1b - t0c0b) % p;
        int C4 = (t1c2a - t0c2a - t0c1a) % p;
        int C5 = (t1c2b - t0c2b - t0c1b) % p;
        int C6 = (2*t0c0a) % p;
        int C7 = (2*t0c0b) % p;
        int C8 = (2*t0c1a) % p;
        int C9 = (2*t0c1b) % p;
        int C10 = (2*t0c2a) % p;
        int C11 = (2*t0c2b) % p;
        return C0,C1,C2,C3,C4,C5,C6,C7,C8,C9,C10,C11;
    }

// Public field operation: preserve the library's canonical [0,p) result
// contract for every other consumer. The integer kernel is deliberately
// repeated so compiler DCE preserves both artifacts' established costs.
function fp12Sqr(
        int A0,int A1,int A2,int A3,int A4,int A5, int A6,int A7,int A8,int A9,int A10,int A11
    ) returns (int,int,int,int,int,int,int,int,int,int,int,int) {
        (int t00a,int t00b) = fp2MulRaw(A0,A1, A6,A7);
        (int t01a,int t01b) = fp2MulRaw(A2,A3, A8,A9);
        (int t02a,int t02b) = fp2MulRaw(A4,A5, A10,A11);
        (int t0p1a,int t0p1b) = fp2MulRaw(A2+A4,A3+A5, A8+A10,A9+A11);
        int t0d2a = t0p1a - t01a - t02a;
        int t0d2b = t0p1b - t01b - t02b;
        int t0c0a = t00a + 9*t0d2a - t0d2b;
        int t0c0b = t00b + t0d2a + 9*t0d2b;
        (int t0p2a,int t0p2b) = fp2MulRaw(A0+A2,A1+A3, A6+A8,A7+A9);
        int t0d4a = t0p2a - t00a - t01a;
        int t0d4b = t0p2b - t00b - t01b;
        int t0c1a = t0d4a + 9*t02a - t02b;
        int t0c1b = t0d4b + t02a + 9*t02b;
        (int t0p3a,int t0p3b) = fp2MulRaw(A0+A4,A1+A5, A6+A10,A7+A11);
        int t0c2a = t0p3a - t00a - t02a + t01a;
        int t0c2b = t0p3b - t00b - t02b + t01b;

        int s0=A0+A6; int s1=A1+A7; int s2=A2+A8;
        int s3=A3+A9; int s4=A4+A10; int s5=A5+A11;
        int u0=A0+9*A10-A11; int u1=A1+A10+9*A11;
        int u2=A2+A6; int u3=A3+A7; int u4=A4+A8; int u5=A5+A9;
        (int t10a,int t10b) = fp2MulRaw(s0,s1, u0,u1);
        (int t11a,int t11b) = fp2MulRaw(s2,s3, u2,u3);
        (int t12a,int t12b) = fp2MulRaw(s4,s5, u4,u5);
        (int t1p1a,int t1p1b) = fp2MulRaw(s2+s4,s3+s5, u2+u4,u3+u5);
        int t1d2a = t1p1a - t11a - t12a;
        int t1d2b = t1p1b - t11b - t12b;
        int t1c0a = t10a + 9*t1d2a - t1d2b;
        int t1c0b = t10b + t1d2a + 9*t1d2b;
        (int t1p2a,int t1p2b) = fp2MulRaw(s0+s2,s1+s3, u0+u2,u1+u3);
        int t1d4a = t1p2a - t10a - t11a;
        int t1d4b = t1p2b - t10b - t11b;
        int t1c1a = t1d4a + 9*t12a - t12b;
        int t1c1b = t1d4b + t12a + 9*t12b;
        (int t1p3a,int t1p3b) = fp2MulRaw(s0+s4,s1+s5, u0+u4,u1+u5);
        int t1c2a = t1p3a - t10a - t12a + t11a;
        int t1c2b = t1p3b - t10b - t12b + t11b;

        int C0 = canonicalFp(t1c0a - t0c0a - (9*t0c2a - t0c2b));
        int C1 = canonicalFp(t1c0b - t0c0b - (t0c2a + 9*t0c2b));
        int C2 = canonicalFp(t1c1a - t0c1a - t0c0a);
        int C3 = canonicalFp(t1c1b - t0c1b - t0c0b);
        int C4 = canonicalFp(t1c2a - t0c2a - t0c1a);
        int C5 = canonicalFp(t1c2b - t0c2b - t0c1b);
        int C6 = canonicalFp(2*t0c0a);
        int C7 = canonicalFp(2*t0c0b);
        int C8 = canonicalFp(2*t0c1a);
        int C9 = canonicalFp(2*t0c1b);
        int C10 = canonicalFp(2*t0c2a);
        int C11 = canonicalFp(2*t0c2b);
        return C0,C1,C2,C3,C4,C5,C6,C7,C8,C9,C10,C11;
    }

// Multiply an Fp12 value X + Y*W by the finite quotient-torus representative
// 1 + T*W, where X,Y,T are in Fp6 and W^2=v. The discarded Fp6 scale means
// the inverse class is represented by 1-T*W, so the same kernel handles both
// c and cInv folds. Two Fp6 products replace fp12Mul's three.
function fp12MulTorus(
        int F0,int F1,int F2,int F3,int F4,int F5, int F6,int F7,int F8,int F9,int F10,int F11,
        int T0,int T1,int T2,int T3,int T4,int T5
    ) returns (int,int,int,int,int,int,int,int,int,int,int,int) {
        (int yt0,int yt1,int yt2,int yt3,int yt4,int yt5) =
            fp6MulRaw(F6,F7,F8,F9,F10,F11, T0,T1,T2,T3,T4,T5);
        (int xt0,int xt1,int xt2,int xt3,int xt4,int xt5) =
            fp6MulRaw(F0,F1,F2,F3,F4,F5, T0,T1,T2,T3,T4,T5);
        return signedFp(F0 + 9*yt4 - yt5), signedFp(F1 + yt4 + 9*yt5),
               signedFp(F2 + yt0), signedFp(F3 + yt1),
               signedFp(F4 + yt2), signedFp(F5 + yt3),
               signedFp(F6 + xt0), signedFp(F7 + xt1),
               signedFp(F8 + xt2), signedFp(F9 + xt3),
               signedFp(F10 + xt4), signedFp(F11 + xt5);
    }

function mul034(
        int F0,int F1,int F2,int F3,int F4,int F5, int F6,int F7,int F8,int F9,int F10,int F11,
        int o0a,int o0b, int o3a,int o3b, int o4a,int o4b
    ) returns (int,int,int,int,int,int,int,int,int,int,int,int) {
        // A = F.c0 * o0.
        (int A0,int A1) = fp2MulRaw(F0, F1, o0a, o0b);
        (int A2,int A3) = fp2MulRaw(F2, F3, o0a, o0b);
        (int A4,int A5) = fp2MulRaw(F4, F5, o0a, o0b);

        // B = F.c1 * (o3 + o4*v).
        (int bt0a,int bt0b) = fp2MulRaw(F6, F7, o3a, o3b);
        (int bt1a,int bt1b) = fp2MulRaw(F8, F9, o4a, o4b);
        (int bm12a,int bm12b) = fp2MulRaw(F8 + F10, F9 + F11, o4a, o4b);
        int bu0a = bm12a - bt1a;
        int bu0b = bm12b - bt1b;
        int B0 = 9 * bu0a - bu0b + bt0a;
        int B1 = bu0a + 9 * bu0b + bt0b;
        (int bm1a,int bm1b) = fp2MulRaw(o3a + o4a, o3b + o4b, F6 + F8, F7 + F9);
        int B2 = bm1a - bt0a - bt1a;
        int B3 = bm1b - bt0b - bt1b;
        (int bm2a,int bm2b) = fp2MulRaw(F6 + F10, F7 + F11, o3a, o3b);
        int B4 = bm2a - bt0a + bt1a;
        int B5 = bm2b - bt0b + bt1b;

        // G = (F.c0 + F.c1) * (o0 + o3 + o4*v).
        int S0 = F0 + F6;
        int S1 = F1 + F7;
        int S2 = F2 + F8;
        int S3 = F3 + F9;
        int S4 = F4 + F10;
        int S5 = F5 + F11;
        int qa = o0a + o3a;
        int qb = o0b + o3b;
        (int gt0a,int gt0b) = fp2MulRaw(S0, S1, qa, qb);
        (int gt1a,int gt1b) = fp2MulRaw(S2, S3, o4a, o4b);
        (int gm12a,int gm12b) = fp2MulRaw(S2 + S4, S3 + S5, o4a, o4b);
        int gu0a = gm12a - gt1a;
        int gu0b = gm12b - gt1b;
        int G0 = 9 * gu0a - gu0b + gt0a;
        int G1 = gu0a + 9 * gu0b + gt0b;
        (int gm1a,int gm1b) = fp2MulRaw(qa + o4a, qb + o4b, S0 + S2, S1 + S3);
        int G2 = gm1a - gt0a - gt1a;
        int G3 = gm1b - gt0b - gt1b;
        (int gm2a,int gm2b) = fp2MulRaw(S0 + S4, S1 + S5, qa, qb);
        int G4 = gm2a - gt0a + gt1a;
        int G5 = gm2b - gt0b + gt1b;

        // The interval derivation in bound_analysis.mjs proves all inputs are < 37*p and each
        // combined limb is > -97*(37*p)^2. Add exactly 132,793*p^2, then reduce canonically.
        int p = 21888242871839275222246405745257275088696311157297823662689037894645226208583;
        int rawBias = 63620485708775397116398918488458420026955112869114471513803213004724729950895225285411156794258613332669998933780976023070021894424298169671600468685695583977;
        return (9 * B4 - B5 + A0 + rawBias) % p, (B4 + 9 * B5 + A1 + rawBias) % p,
               (B0 + A2 + rawBias) % p, (B1 + A3 + rawBias) % p,
               (B2 + A4 + rawBias) % p, (B3 + A5 + rawBias) % p,
               (G0 - A0 - B0 + rawBias) % p, (G1 - A1 - B1 + rawBias) % p,
               (G2 - A2 - B2 + rawBias) % p, (G3 - A3 - B3 + rawBias) % p,
               (G4 - A4 - B4 + rawBias) % p, (G5 - A5 - B5 + rawBias) % p;
    }

// Sparse Fp12 multiply specialized for o0=1. A=F.c0 is free, and the G-side constant
// becomes (1+o3), removing three fp2MulRaw calls from every Miller line.
function mul034Unit(
        int F0,int F1,int F2,int F3,int F4,int F5, int F6,int F7,int F8,int F9,int F10,int F11,
        int o3a,int o3b, int o4a,int o4b
    ) returns (int,int,int,int,int,int,int,int,int,int,int,int) {
        (int bt0a,int bt0b) = fp2MulRaw(F6, F7, o3a, o3b);
        (int bt1a,int bt1b) = fp2MulRaw(F8, F9, o4a, o4b);
        (int bm12a,int bm12b) = fp2MulRaw(F8 + F10, F9 + F11, o4a, o4b);
        int bu0a = bm12a - bt1a;
        int bu0b = bm12b - bt1b;
        int B0 = 9 * bu0a - bu0b + bt0a;
        int B1 = bu0a + 9 * bu0b + bt0b;
        (int bm1a,int bm1b) = fp2MulRaw(o3a + o4a, o3b + o4b, F6 + F8, F7 + F9);
        int B2 = bm1a - bt0a - bt1a;
        int B3 = bm1b - bt0b - bt1b;
        (int bm2a,int bm2b) = fp2MulRaw(F6 + F10, F7 + F11, o3a, o3b);
        int B4 = bm2a - bt0a + bt1a;
        int B5 = bm2b - bt0b + bt1b;

        int S0 = F0 + F6;
        int S1 = F1 + F7;
        int S2 = F2 + F8;
        int S3 = F3 + F9;
        int S4 = F4 + F10;
        int S5 = F5 + F11;
        int qa = 1 + o3a;
        int qb = o3b;
        (int gt0a,int gt0b) = fp2MulRaw(S0, S1, qa, qb);
        (int gt1a,int gt1b) = fp2MulRaw(S2, S3, o4a, o4b);
        (int gm12a,int gm12b) = fp2MulRaw(S2 + S4, S3 + S5, o4a, o4b);
        int gu0a = gm12a - gt1a;
        int gu0b = gm12b - gt1b;
        int G0 = 9 * gu0a - gu0b + gt0a;
        int G1 = gu0a + 9 * gu0b + gt0b;
        (int gm1a,int gm1b) = fp2MulRaw(qa + o4a, qb + o4b, S0 + S2, S1 + S3);
        int G2 = gm1a - gt0a - gt1a;
        int G3 = gm1b - gt0b - gt1b;
        (int gm2a,int gm2b) = fp2MulRaw(S0 + S4, S1 + S5, qa, qb);
        int G4 = gm2a - gt0a + gt1a;
        int G5 = gm2b - gt0b + gt1b;

        // unit_line_bound_analysis.mjs proves the same 132,793*p^2 bias is positive for canonical
        // F/o3/o4 limbs (the derived qa is in [1,p]); the shared multiple of p preserves residues.
        int p = 21888242871839275222246405745257275088696311157297823662689037894645226208583;
        int rawBias = 63620485708775397116398918488458420026955112869114471513803213004724729950895225285411156794258613332669998933780976023070021894424298169671600468685695583977;
        return (9 * B4 - B5 + F0 + rawBias) % p, (B4 + 9 * B5 + F1 + rawBias) % p,
               (B0 + F2 + rawBias) % p, (B1 + F3 + rawBias) % p,
               (B2 + F4 + rawBias) % p, (B3 + F5 + rawBias) % p,
               (G0 - F0 - B0 + rawBias) % p, (G1 - F1 - B1 + rawBias) % p,
               (G2 - F2 - B2 + rawBias) % p, (G3 - F3 - B3 + rawBias) % p,
               (G4 - F4 - B4 + rawBias) % p, (G5 - F5 - B5 + rawBias) % p;
    }

function lineUnitDirect(
        int F0,int F1,int F2,int F3,int F4,int F5, int F6,int F7,int F8,int F9,int F10,int F11,
        int c0a,int c0b,int c1a,int c1b, int u, int v
    ) returns (int,int,int,int,int,int,int,int,int,int,int,int) {
        int p = 21888242871839275222246405745257275088696311157297823662689037894645226208583;
        int o3a = (c1a * u) % p;
        int o3b = (c1b * u) % p;
        int o4a = (c0a * v) % p;
        int o4b = (c0b * v) % p;
        int opa = o3a + o4a; int opb = o3b + o4b;
        int oma = o3a - o4a; int omb = o3b - o4b;
        (int ym0a,int ym0b) = fp2MulRaw(F6,F7, o3a,o3b);
        (int ym3a,int ym3b) = fp2MulRaw(F10,F11, o4a,o4b);
        (int ympa,int ympb) = fp2MulRaw(F6+F8+F10,F7+F9+F11, opa,opb);
        (int ymma,int ymmb) = fp2MulRaw(F6-F8+F10,F7-F9+F11, oma,omb);
        int yt0 = ym0a+9*ym3a-ym3b; int yt1 = ym0b+ym3a+9*ym3b;
        int yt2 = ((ympa-ymma)>>1)-ym3a; int yt3 = ((ympb-ymmb)>>1)-ym3b;
        int yt4 = ((ympa+ymma)>>1)-ym0a; int yt5 = ((ympb+ymmb)>>1)-ym0b;

        (int xm0a,int xm0b) = fp2MulRaw(F0,F1, o3a,o3b);
        (int xm3a,int xm3b) = fp2MulRaw(F4,F5, o4a,o4b);
        (int xmpa,int xmpb) = fp2MulRaw(F0+F2+F4,F1+F3+F5, opa,opb);
        (int xmma,int xmmb) = fp2MulRaw(F0-F2+F4,F1-F3+F5, oma,omb);
        int xt0 = xm0a+9*xm3a-xm3b; int xt1 = xm0b+xm3a+9*xm3b;
        int xt2 = ((xmpa-xmma)>>1)-xm3a; int xt3 = ((xmpb-xmmb)>>1)-xm3b;
        int xt4 = ((xmpa+xmma)>>1)-xm0a; int xt5 = ((xmpb+xmmb)>>1)-xm0b;

        return (F0 + 9*yt4 - yt5) % p, (F1 + yt4 + 9*yt5) % p,
               (F2 + yt0) % p, (F3 + yt1) % p,
               (F4 + yt2) % p, (F5 + yt3) % p,
               (F6 + xt0) % p, (F7 + xt1) % p,
               (F8 + xt2) % p, (F9 + xt3) % p,
               (F10 + xt4) % p, (F11 + xt5) % p;
    }

function line(
        int F0,int F1,int F2,int F3,int F4,int F5,int F6,int F7,int F8,int F9,int F10,int F11,
        int c0a,int c0b,int c1a,int c1b,int c2a,int c2b, int Px, int Py
    ) returns (int,int,int,int,int,int,int,int,int,int,int,int) {
        int o0a = mulFp(c2a, Py);
        int o0b = mulFp(c2b, Py);
        int o3a = mulFp(c1a, Px);
        int o3b = mulFp(c1b, Px);
        (int r0,int r1,int r2,int r3,int r4,int r5,int r6,int r7,int r8,int r9,int r10,int r11) =
            mul034(F0,F1,F2,F3,F4,F5,F6,F7,F8,F9,F10,F11, o0a,o0b, o3a,o3b, c0a,c0b);
        return r0,r1,r2,r3,r4,r5,r6,r7,r8,r9,r10,r11;
    }

function lineUnit(
        int F0,int F1,int F2,int F3,int F4,int F5,int F6,int F7,int F8,int F9,int F10,int F11,
        int c0a,int c0b,int c1a,int c1b, int u, int v
    ) returns (int,int,int,int,int,int,int,int,int,int,int,int) {
        int o3a = mulFp(c1a, u);
        int o3b = mulFp(c1b, u);
        int o4a = mulFp(c0a, v);
        int o4b = mulFp(c0b, v);
        (int r0,int r1,int r2,int r3,int r4,int r5,int r6,int r7,int r8,int r9,int r10,int r11) =
            mul034Unit(F0,F1,F2,F3,F4,F5,F6,F7,F8,F9,F10,F11, o3a,o3b, o4a,o4b);
        return r0,r1,r2,r3,r4,r5,r6,r7,r8,r9,r10,r11;
    }

// Runtime-G2 affine Miller steps. Each caller supplies a canonical slope witness. The explicit
// nonzero-denominator gates exclude the equal/inverse exceptional cases, so the slope equation
// uniquely binds the tangent/chord. New affine state is canonical; normalized lines use c2=-1.
function pointDoubleAffine(int Xa,int Xb,int Ya,int Yb,int ma,int mb)
    returns (int,int,int,int, int,int,int,int) {
        int p = 21888242871839275222246405745257275088696311157297823662689037894645226208583;
        require(within(ma, 0, p)); require(within(mb, 0, p));
        require(Ya % p != 0 || Yb % p != 0);
        // Affine state is canonical: these additions stay below 2p/3p, and each consumer reduces.
        int twoYa = Ya + Ya; int twoYb = Yb + Yb;
        (int slopeLhsA,int slopeLhsB) = fp2Mul(ma, mb, twoYa, twoYb);
        (int x2a,int x2b) = fp2Sqr(Xa, Xb);
        int slopeRhsA = x2a + x2a + x2a; int slopeRhsB = x2b + x2b + x2b;
        require((slopeLhsA - slopeRhsA) % p == 0);
        require((slopeLhsB - slopeRhsB) % p == 0);
        (int m2a,int m2b) = fp2Sqr(ma, mb);
        int twoXa = Xa + Xa; int twoXb = Xb + Xb;
        int nXa = canonicalFp(m2a - twoXa); int nXb = canonicalFp(m2b - twoXb);
        (int xdnXa,int xdnXb) = fp2Sub(Xa, Xb, nXa, nXb, 1);
        (int mxdnXa,int mxdnXb) = fp2Mul(ma, mb, xdnXa, xdnXb);
        int nYa = canonicalFp(mxdnXa - Ya); int nYb = canonicalFp(mxdnXb - Yb);
        (int mxA,int mxB) = fp2Mul(ma, mb, Xa, Xb);
        (int c0a,int c0b) = fp2Sub(Ya, Yb, mxA, mxB, 1);
        return c0a,c0b,ma,mb, nXa,nXb,nYa,nYb;
    }

function pointAddAffine(int Xa,int Xb,int Ya,int Yb, int Qxa,int Qxb,int Qya,int Qyb, int ma,int mb)
    returns (int,int,int,int, int,int,int,int) {
        int p = 21888242871839275222246405745257275088696311157297823662689037894645226208583;
        require(within(ma, 0, p)); require(within(mb, 0, p));
        (int dxa,int dxb) = fp2Sub(Qxa, Qxb, Xa, Xb, 1);
        require(dxa % p != 0 || dxb % p != 0);
        (int dya,int dyb) = fp2Sub(Qya, Qyb, Ya, Yb, 1);
        (int slopeLhsA,int slopeLhsB) = fp2Mul(ma, mb, dxa, dxb);
        require((slopeLhsA - dya) % p == 0); require((slopeLhsB - dyb) % p == 0);
        (int m2a,int m2b) = fp2Sqr(ma, mb);
        (int txa,int txb) = fp2Sub(m2a, m2b, Xa, Xb, 1);
        (int nxRawA,int nxRawB) = fp2Sub(txa, txb, Qxa, Qxb, 1);
        int nXa = canonicalFp(nxRawA); int nXb = canonicalFp(nxRawB);
        (int xdnXa,int xdnXb) = fp2Sub(Xa, Xb, nXa, nXb, 1);
        (int mxdnXa,int mxdnXb) = fp2Mul(ma, mb, xdnXa, xdnXb);
        int nYa = canonicalFp(mxdnXa - Ya); int nYb = canonicalFp(mxdnXb - Yb);
        (int mxA,int mxB) = fp2Mul(ma, mb, Xa, Xb);
        (int c0a,int c0b) = fp2Sub(Ya, Yb, mxA, mxB, 1);
        return c0a,c0b,ma,mb, nXa,nXb,nYa,nYb;
    }

function pointDouble(int Xa,int Xb,int Ya,int Yb,int Za,int Zb)
        returns (int,int,int,int,int,int, int,int,int,int,int,int) {
        (int t0a,int t0b) = fp2Sqr(Ya, Yb);
        (int t1a,int t1b) = fp2Sqr(Za, Zb);
        (int s1a,int s1b) = fp2Scale(t1a, t1b, 3);
        (int t2a,int t2b) = fp2MulByB(s1a, s1b);
        (int t3a,int t3b) = fp2Scale(t2a, t2b, 3);
        (int yza,int yzb) = fp2Add(Ya, Yb, Za, Zb);
        (int sq_a,int sq_b) = fp2Sqr(yza, yzb);
        (int u4a,int u4b) = fp2Sub(sq_a, sq_b, t1a, t1b, 1);
        (int t4a,int t4b) = fp2Sub(u4a, u4b, t0a, t0b, 1);
        (int c0a,int c0b) = fp2Sub(t2a, t2b, t0a, t0b, 1);
        (int rxq_a,int rxq_b) = fp2Sqr(Xa, Xb);
        (int c1a,int c1b) = fp2Scale(rxq_a, rxq_b, 3);
        (int c2a,int c2b) = fp2Neg(t4a, t4b, 64);
        (int da,int db) = fp2Sub(t0a, t0b, t3a, t3b, 1);
        (int dxa,int dxb) = fp2Mul(da, db, Xa, Xb);
        (int dxya,int dxyb) = fp2Mul(dxa, dxb, Ya, Yb);
        (int nxa,int nxb) = fp2Half(dxya, dxyb);
        (int sa,int sb) = fp2Add(t0a, t0b, t3a, t3b);
        (int sha,int shb) = fp2Half(sa, sb);
        (int sh2a,int sh2b) = fp2Sqr(sha, shb);
        (int t2sa,int t2sb) = fp2Sqr(t2a, t2b);
        (int t2s3a,int t2s3b) = fp2Scale(t2sa, t2sb, 3);
        (int nya,int nyb) = fp2Sub(sh2a, sh2b, t2s3a, t2s3b, 1);
        (int nza,int nzb) = fp2Mul(t0a, t0b, t4a, t4b);
        return c0a,c0b,c1a,c1b,c2a,c2b, nxa,nxb,nya,nyb,nza,nzb;
    }

function pointAdd(int Xa,int Xb,int Ya,int Yb,int Za,int Zb, int Qxa,int Qxb,int Qya,int Qyb)
        returns (int,int,int,int,int,int, int,int,int,int,int,int) {
        (int qyz_a,int qyz_b) = fp2Mul(Qya, Qyb, Za, Zb);
        (int t0a,int t0b) = fp2Sub(Ya, Yb, qyz_a, qyz_b, 3);
        (int qxz_a,int qxz_b) = fp2Mul(Qxa, Qxb, Za, Zb);
        (int t1a,int t1b) = fp2Sub(Xa, Xb, qxz_a, qxz_b, 3);
        (int t0qx_a,int t0qx_b) = fp2Mul(t0a, t0b, Qxa, Qxb);
        (int t1qy_a,int t1qy_b) = fp2Mul(t1a, t1b, Qya, Qyb);
        (int c0a,int c0b) = fp2Sub(t0qx_a, t0qx_b, t1qy_a, t1qy_b, 3);
        (int c1a,int c1b) = fp2Neg(t0a, t0b, 64);
        int c2a = t1a;
        int c2b = t1b;
        (int t2a,int t2b) = fp2Sqr(t1a, t1b);
        (int t3a,int t3b) = fp2Mul(t2a, t2b, t1a, t1b);
        (int t4a,int t4b) = fp2Mul(t2a, t2b, Xa, Xb);
        (int t42a,int t42b) = fp2Scale(t4a, t4b, 2);
        (int d35a,int d35b) = fp2Sub(t3a, t3b, t42a, t42b, 1);
        (int t0sa,int t0sb) = fp2Sqr(t0a, t0b);
        (int t0sza,int t0szb) = fp2Mul(t0sa, t0sb, Za, Zb);
        (int t5a,int t5b) = fp2Add(d35a, d35b, t0sza, t0szb);
        (int nxa,int nxb) = fp2Mul(t1a, t1b, t5a, t5b);
        (int d45a,int d45b) = fp2Sub(t4a, t4b, t5a, t5b, 7);
        (int d45t0a,int d45t0b) = fp2Mul(d45a, d45b, t0a, t0b);
        (int t3rya,int t3ryb) = fp2Mul(t3a, t3b, Ya, Yb);
        (int nya,int nyb) = fp2Sub(d45t0a, d45t0b, t3rya, t3ryb, 3);
        (int nza,int nzb) = fp2Mul(Za, Zb, t3a, t3b);
        return c0a,c0b,c1a,c1b,c2a,c2b, nxa,nxb,nya,nyb,nza,nzb;
    }

function psi(int xa,int xb,int ya,int yb) returns (int,int,int,int) {
        (int cxa,int cxb) = fp2Conj(xa, xb, 64);
        (int pxa,int pxb) = fp2Mul(cxa, cxb,
            21575463638280843010398324269430826099269044274347216827212613867836435027261,
            10307601595873709700152284273816112264069230130616436755625194854815875713954);
        (int cya,int cyb) = fp2Conj(ya, yb, 64);
        (int pya,int pyb) = fp2Mul(cya, cyb,
            2821565182194536844548159561693502659359617185244120367078079554186484126554,
            3505843767911556378687030309984248845540243509899259641013678093033130930403);
        return pxa, pxb, pya, pyb;
    }

function inverseFp(int x) returns (int) {
        int p = 21888242871839275222246405745257275088696311157297823662689037894645226208583;
        int q = p - 2;
        int result = 1;
        int current = x % p;
        for (int i = 0; i < 254; i = i + 1) {
            if (((q >> i) % 2) == 1) { result = (result * current) % p; }
            current = (current * current) % p;
        }
        return result;
    }

function fp2Inv(int a0, int a1) returns (int, int) {
        int factor = inverseFp(addFp(mulFp(a0, a0), mulFp(a1, a1)));
        return mulFp(a0, factor), subFp(0, mulFp(a1, factor), 1);
    }

function fp6Neg(int a0a,int a0b,int a1a,int a1b,int a2a,int a2b, int k) returns (int,int,int,int,int,int) {
        (int c0a, int c0b) = fp2Neg(a0a, a0b, k);
        (int c1a, int c1b) = fp2Neg(a1a, a1b, k);
        (int c2a, int c2b) = fp2Neg(a2a, a2b, k);
        return c0a, c0b, c1a, c1b, c2a, c2b;
    }

function fp6Inv(int c0a,int c0b,int c1a,int c1b,int c2a,int c2b) returns (int,int,int,int,int,int) {
        (int sq0a,int sq0b) = fp2Sqr(c0a, c0b);
        (int m21a,int m21b) = fp2Mul(c2a, c2b, c1a, c1b);
        (int xm21a,int xm21b) = fp2MulXi(m21a, m21b, 3);
        (int t0a,int t0b) = fp2Sub(sq0a, sq0b, xm21a, xm21b, 4);
        (int sq2a,int sq2b) = fp2Sqr(c2a, c2b);
        (int xsq2a,int xsq2b) = fp2MulXi(sq2a, sq2b, 1);
        (int m01a,int m01b) = fp2Mul(c0a, c0b, c1a, c1b);
        (int t1a,int t1b) = fp2Sub(xsq2a, xsq2b, m01a, m01b, 3);
        (int sq1a,int sq1b) = fp2Sqr(c1a, c1b);
        (int m02a,int m02b) = fp2Mul(c0a, c0b, c2a, c2b);
        (int t2a,int t2b) = fp2Sub(sq1a, sq1b, m02a, m02b, 3);
        (int ct1a,int ct1b) = fp2Mul(c2a, c2b, t1a, t1b);
        (int ct2a,int ct2b) = fp2Mul(c1a, c1b, t2a, t2b);
        (int suma,int sumb) = fp2Add(ct1a, ct1b, ct2a, ct2b);
        (int xa,int xb) = fp2MulXi(suma, sumb, 6);
        (int c0t0a,int c0t0b) = fp2Mul(c0a, c0b, t0a, t0b);
        (int na,int nb) = fp2Add(xa, xb, c0t0a, c0t0b);
        (int fa,int fb) = fp2Inv(na, nb);
        (int r0a,int r0b) = fp2Mul(fa, fb, t0a, t0b);
        (int r1a,int r1b) = fp2Mul(fa, fb, t1a, t1b);
        (int r2a,int r2b) = fp2Mul(fa, fb, t2a, t2b);
        return r0a, r0b, r1a, r1b, r2a, r2b;
    }

function fp6FrobOdd(int x0a,int x0b,int x1a,int x1b,int x2a,int x2b, int k1a,int k1b,int k2a,int k2b) returns (int,int,int,int,int,int) {
        (int d0a,int d0b) = fp2Conj(x0a, x0b, 64);
        (int c1a,int c1b) = fp2Conj(x1a, x1b, 64);
        (int d1a,int d1b) = fp2Mul(c1a, c1b, k1a, k1b);
        (int c2a,int c2b) = fp2Conj(x2a, x2b, 64);
        (int d2a,int d2b) = fp2Mul(c2a, c2b, k2a, k2b);
        return d0a, d0b, d1a, d1b, d2a, d2b;
    }

function fp6FrobEven(int x0a,int x0b,int x1a,int x1b,int x2a,int x2b, int k1a,int k1b,int k2a,int k2b) returns (int,int,int,int,int,int) {
        (int d1a,int d1b) = fp2Mul(x1a, x1b, k1a, k1b);
        (int d2a,int d2b) = fp2Mul(x2a, x2b, k2a, k2b);
        return x0a, x0b, d1a, d1b, d2a, d2b;
    }

function fp6MulByFp2(int x0a,int x0b,int x1a,int x1b,int x2a,int x2b, int ka,int kb) returns (int,int,int,int,int,int) {
        (int r0a,int r0b) = fp2Mul(x0a, x0b, ka, kb);
        (int r1a,int r1b) = fp2Mul(x1a, x1b, ka, kb);
        (int r2a,int r2b) = fp2Mul(x2a, x2b, ka, kb);
        return r0a, r0b, r1a, r1b, r2a, r2b;
    }

function fp12Conj(int A0,int A1,int A2,int A3,int A4,int A5, int A6,int A7,int A8,int A9,int A10,int A11)
        returns (int,int,int,int,int,int,int,int,int,int,int,int) {
        (int N6,int N7,int N8,int N9,int N10,int N11) = fp6Neg(A6,A7,A8,A9,A10,A11, 64);
        return A0,A1,A2,A3,A4,A5,N6,N7,N8,N9,N10,N11;
    }

function fp12Inv(int A0,int A1,int A2,int A3,int A4,int A5, int A6,int A7,int A8,int A9,int A10,int A11)
        returns (int,int,int,int,int,int,int,int,int,int,int,int) {
        (int sc0_0,int sc0_1,int sc0_2,int sc0_3,int sc0_4,int sc0_5) = fp6Mul(A0,A1,A2,A3,A4,A5, A0,A1,A2,A3,A4,A5);
        (int sc1_0,int sc1_1,int sc1_2,int sc1_3,int sc1_4,int sc1_5) = fp6Mul(A6,A7,A8,A9,A10,A11, A6,A7,A8,A9,A10,A11);
        (int vc_0,int vc_1,int vc_2,int vc_3,int vc_4,int vc_5) = fp6MulByV(sc1_0,sc1_1,sc1_2,sc1_3,sc1_4,sc1_5, 12);
        (int dn_0,int dn_1,int dn_2,int dn_3,int dn_4,int dn_5) = fp6Sub(sc0_0,sc0_1,sc0_2,sc0_3,sc0_4,sc0_5, vc_0,vc_1,vc_2,vc_3,vc_4,vc_5, 13);
        (int t_0,int t_1,int t_2,int t_3,int t_4,int t_5) = fp6Inv(dn_0,dn_1,dn_2,dn_3,dn_4,dn_5);
        (int n0,int n1,int n2,int n3,int n4,int n5) = fp6Mul(A0,A1,A2,A3,A4,A5, t_0,t_1,t_2,t_3,t_4,t_5);
        (int u0,int u1,int u2,int u3,int u4,int u5) = fp6Mul(A6,A7,A8,A9,A10,A11, t_0,t_1,t_2,t_3,t_4,t_5);
        (int w0,int w1,int w2,int w3,int w4,int w5) = fp6Neg(u0,u1,u2,u3,u4,u5, 12);
        return n0,n1,n2,n3,n4,n5,w0,w1,w2,w3,w4,w5;
    }

function fp12Frob1(int A0,int A1,int A2,int A3,int A4,int A5, int A6,int A7,int A8,int A9,int A10,int A11)
