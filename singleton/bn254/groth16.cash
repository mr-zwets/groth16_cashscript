    // cyclotomic squaring (noble _cyclotomicSquare via Fp4Square)
    function fp4Square(int a0,int a1,int b0,int b1) returns (int,int,int,int) {
        (int a2a,int a2b) = fp2Sqr(a0, a1);
        (int b2a,int b2b) = fp2Sqr(b0, b1);
        (int xbi0,int xbi1) = fp2MulXi(b2a, b2b);
        (int f0,int f1) = fp2Add(xbi0, xbi1, a2a, a2b);
        (int aba,int abb) = fp2Add(a0, a1, b0, b1);
        (int absqa,int absqb) = fp2Sqr(aba, abb);
        (int sub1a,int sub1b) = fp2Sub(absqa, absqb, a2a, a2b);
        (int s0,int s1) = fp2Sub(sub1a, sub1b, b2a, b2b);
        return f0, f1, s0, s1;
    }
    function cycSqr(int A0,int A1,int A2,int A3,int A4,int A5, int A6,int A7,int A8,int A9,int A10,int A11)
        returns (int,int,int,int,int,int,int,int,int,int,int,int) {
        // c0c0=A0A1 c0c1=A2A3 c0c2=A4A5  c1c0=A6A7 c1c1=A8A9 c1c2=A10A11
        (int t3a,int t3b,int t4a,int t4b) = fp4Square(A0,A1, A8,A9);
        (int t5a,int t5b,int t6a,int t6b) = fp4Square(A6,A7, A4,A5);
        (int t7a,int t7b,int t8a,int t8b) = fp4Square(A2,A3, A10,A11);
        (int t9a,int t9b) = fp2MulXi(t8a, t8b);
        // out c0ci = 2*(Ti - c0ci) + Ti ; out c1ci = 2*(Ti + c1ci) + Ti
        (int z0a,int z0b) = fp2Sub(t3a, t3b, A0, A1);   (int o0a,int o0b) = fp2Add(mulFp(z0a,2), mulFp(z0b,2), t3a, t3b);
        (int z1a,int z1b) = fp2Sub(t5a, t5b, A2, A3);   (int o1a,int o1b) = fp2Add(mulFp(z1a,2), mulFp(z1b,2), t5a, t5b);
        (int z2a,int z2b) = fp2Sub(t7a, t7b, A4, A5);   (int o2a,int o2b) = fp2Add(mulFp(z2a,2), mulFp(z2b,2), t7a, t7b);
        (int z3a,int z3b) = fp2Add(t9a, t9b, A6, A7);   (int o3a,int o3b) = fp2Add(mulFp(z3a,2), mulFp(z3b,2), t9a, t9b);
        (int z4a,int z4b) = fp2Add(t4a, t4b, A8, A9);   (int o4a,int o4b) = fp2Add(mulFp(z4a,2), mulFp(z4b,2), t4a, t4b);
        (int z5a,int z5b) = fp2Add(t6a, t6b, A10, A11); (int o5a,int o5b) = fp2Add(mulFp(z5a,2), mulFp(z5b,2), t6a, t6b);
        return o0a,o0b,o1a,o1b,o2a,o2b,o3a,o3b,o4a,o4b,o5a,o5b;
    }
    // cyclotomicExp(num, BN_X) — square-and-multiply over the 63 bits of X (MSB-first)
    function cycExpX(int N0,int N1,int N2,int N3,int N4,int N5,int N6,int N7,int N8,int N9,int N10,int N11)
        returns (int,int,int,int,int,int,int,int,int,int,int,int) {
        int Z0=1; int Z1=0; int Z2=0; int Z3=0; int Z4=0; int Z5=0; int Z6=0; int Z7=0; int Z8=0; int Z9=0; int Z10=0; int Z11=0;
        for (int k = 0; k < 63; k = k + 1) {
            int i = 62 - k;
            (int s0,int s1,int s2,int s3,int s4,int s5,int s6,int s7,int s8,int s9,int s10,int s11) =
                cycSqr(Z0,Z1,Z2,Z3,Z4,Z5,Z6,Z7,Z8,Z9,Z10,Z11);
            Z0=s0; Z1=s1; Z2=s2; Z3=s3; Z4=s4; Z5=s5; Z6=s6; Z7=s7; Z8=s8; Z9=s9; Z10=s10; Z11=s11;
            if (((4965661367192848881 >> i) % 2) == 1) {
                (int m0,int m1,int m2,int m3,int m4,int m5,int m6,int m7,int m8,int m9,int m10,int m11) =
                    fp12Mul(Z0,Z1,Z2,Z3,Z4,Z5,Z6,Z7,Z8,Z9,Z10,Z11, N0,N1,N2,N3,N4,N5,N6,N7,N8,N9,N10,N11);
                Z0=m0; Z1=m1; Z2=m2; Z3=m3; Z4=m4; Z5=m5; Z6=m6; Z7=m7; Z8=m8; Z9=m9; Z10=m10; Z11=m11;
            }
        }
        return Z0,Z1,Z2,Z3,Z4,Z5,Z6,Z7,Z8,Z9,Z10,Z11;
    }
    // powMinusX = conj(cycExpX(num))   (X is the positive BN seed; conj for the negation)
    function powMinusX(int N0,int N1,int N2,int N3,int N4,int N5,int N6,int N7,int N8,int N9,int N10,int N11)
        returns (int,int,int,int,int,int,int,int,int,int,int,int) {
        (int p0,int p1,int p2,int p3,int p4,int p5,int p6,int p7,int p8,int p9,int p10,int p11) =
            cycExpX(N0,N1,N2,N3,N4,N5,N6,N7,N8,N9,N10,N11);
        (int c0,int c1,int c2,int c3,int c4,int c5,int c6,int c7,int c8,int c9,int c10,int c11) =
            fp12Conj(p0,p1,p2,p3,p4,p5,p6,p7,p8,p9,p10,p11);
        return c0,c1,c2,c3,c4,c5,c6,c7,c8,c9,c10,c11;
    }

    function finalExp(int A0,int A1,int A2,int A3,int A4,int A5,int A6,int A7,int A8,int A9,int A10,int A11)
        returns (int,int,int,int,int,int,int,int,int,int,int,int) {
        // easy part: r0 = conj(f) * inv(f)
        (int cn0,int cn1,int cn2,int cn3,int cn4,int cn5,int cn6,int cn7,int cn8,int cn9,int cn10,int cn11) =
            fp12Conj(A0,A1,A2,A3,A4,A5,A6,A7,A8,A9,A10,A11);
        (int iv0,int iv1,int iv2,int iv3,int iv4,int iv5,int iv6,int iv7,int iv8,int iv9,int iv10,int iv11) =
            fp12Inv(A0,A1,A2,A3,A4,A5,A6,A7,A8,A9,A10,A11);
        (int r0a,int r0b,int r0c,int r0d,int r0e,int r0f,int r0g,int r0h,int r0i,int r0j,int r0k,int r0l) =
            fp12Mul(cn0,cn1,cn2,cn3,cn4,cn5,cn6,cn7,cn8,cn9,cn10,cn11, iv0,iv1,iv2,iv3,iv4,iv5,iv6,iv7,iv8,iv9,iv10,iv11);
        // r = frob2(r0) * r0
        (int fr0,int fr1,int fr2,int fr3,int fr4,int fr5,int fr6,int fr7,int fr8,int fr9,int fr10,int fr11) =
            fp12Frob2(r0a,r0b,r0c,r0d,r0e,r0f,r0g,r0h,r0i,r0j,r0k,r0l);
        (int R0,int R1,int R2,int R3,int R4,int R5,int R6,int R7,int R8,int R9,int R10,int R11) =
            fp12Mul(fr0,fr1,fr2,fr3,fr4,fr5,fr6,fr7,fr8,fr9,fr10,fr11, r0a,r0b,r0c,r0d,r0e,r0f,r0g,r0h,r0i,r0j,r0k,r0l);
        // hard part
        (int pm0,int pm1,int pm2,int pm3,int pm4,int pm5,int pm6,int pm7,int pm8,int pm9,int pm10,int pm11) =
            powMinusX(R0,R1,R2,R3,R4,R5,R6,R7,R8,R9,R10,R11);
        (int y10,int y11_,int y12,int y13,int y14,int y15,int y16,int y17,int y18,int y19,int y1a,int y1b) =
            cycSqr(pm0,pm1,pm2,pm3,pm4,pm5,pm6,pm7,pm8,pm9,pm10,pm11);
        (int cy10,int cy11,int cy12,int cy13,int cy14,int cy15,int cy16,int cy17,int cy18,int cy19,int cy1a,int cy1b) =
            cycSqr(y10,y11_,y12,y13,y14,y15,y16,y17,y18,y19,y1a,y1b);
        (int y20,int y21,int y22,int y23,int y24,int y25,int y26,int y27,int y28,int y29,int y2a,int y2b) =
            fp12Mul(cy10,cy11,cy12,cy13,cy14,cy15,cy16,cy17,cy18,cy19,cy1a,cy1b, y10,y11_,y12,y13,y14,y15,y16,y17,y18,y19,y1a,y1b);
        (int y40,int y41,int y42,int y43,int y44,int y45,int y46,int y47,int y48,int y49,int y4a,int y4b) =
            powMinusX(y20,y21,y22,y23,y24,y25,y26,y27,y28,y29,y2a,y2b);
        (int cy40,int cy41,int cy42,int cy43,int cy44,int cy45,int cy46,int cy47,int cy48,int cy49,int cy4a,int cy4b) =
            cycSqr(y40,y41,y42,y43,y44,y45,y46,y47,y48,y49,y4a,y4b);
        (int y60,int y61,int y62,int y63,int y64,int y65,int y66,int y67,int y68,int y69,int y6a,int y6b) =
            powMinusX(cy40,cy41,cy42,cy43,cy44,cy45,cy46,cy47,cy48,cy49,cy4a,cy4b);
        // y8 = conj(y6)*y4*conj(y2)
        (int ny60,int ny61,int ny62,int ny63,int ny64,int ny65,int ny66,int ny67,int ny68,int ny69,int ny6a,int ny6b) =
            fp12Conj(y60,y61,y62,y63,y64,y65,y66,y67,y68,y69,y6a,y6b);
        (int t8a,int t8b,int t8c,int t8d,int t8e,int t8f,int t8g,int t8h,int t8i,int t8j,int t8k,int t8l) =
            fp12Mul(ny60,ny61,ny62,ny63,ny64,ny65,ny66,ny67,ny68,ny69,ny6a,ny6b, y40,y41,y42,y43,y44,y45,y46,y47,y48,y49,y4a,y4b);
        (int ny20,int ny21,int ny22,int ny23,int ny24,int ny25,int ny26,int ny27,int ny28,int ny29,int ny2a,int ny2b) =
            fp12Conj(y20,y21,y22,y23,y24,y25,y26,y27,y28,y29,y2a,y2b);
        (int y80,int y81,int y82,int y83,int y84,int y85,int y86,int y87,int y88,int y89,int y8a,int y8b) =
            fp12Mul(t8a,t8b,t8c,t8d,t8e,t8f,t8g,t8h,t8i,t8j,t8k,t8l, ny20,ny21,ny22,ny23,ny24,ny25,ny26,ny27,ny28,ny29,ny2a,ny2b);
        // y9 = y8*y1
        (int y90,int y91,int y92,int y93,int y94,int y95,int y96,int y97,int y98,int y99,int y9a,int y9b) =
            fp12Mul(y80,y81,y82,y83,y84,y85,y86,y87,y88,y89,y8a,y8b, y10,y11_,y12,y13,y14,y15,y16,y17,y18,y19,y1a,y1b);
        // left = frob3(conj(r)*y9)
        (int cr0,int cr1,int cr2,int cr3,int cr4,int cr5,int cr6,int cr7,int cr8,int cr9,int cra,int crb) =
            fp12Conj(R0,R1,R2,R3,R4,R5,R6,R7,R8,R9,R10,R11);
        (int cry90,int cry91,int cry92,int cry93,int cry94,int cry95,int cry96,int cry97,int cry98,int cry99,int cry9a,int cry9b) =
            fp12Mul(cr0,cr1,cr2,cr3,cr4,cr5,cr6,cr7,cr8,cr9,cra,crb, y90,y91,y92,y93,y94,y95,y96,y97,y98,y99,y9a,y9b);
        (int L0,int L1,int L2,int L3,int L4,int L5,int L6,int L7,int L8,int L9,int La,int Lb) =
            fp12Frob3(cry90,cry91,cry92,cry93,cry94,cry95,cry96,cry97,cry98,cry99,cry9a,cry9b);
        // right = frob2(y8) * ( frob1(y9) * ((y8*y4)*r) )
        (int f2y80,int f2y81,int f2y82,int f2y83,int f2y84,int f2y85,int f2y86,int f2y87,int f2y88,int f2y89,int f2y8a,int f2y8b) =
            fp12Frob2(y80,y81,y82,y83,y84,y85,y86,y87,y88,y89,y8a,y8b);
        (int f1y90,int f1y91,int f1y92,int f1y93,int f1y94,int f1y95,int f1y96,int f1y97,int f1y98,int f1y99,int f1y9a,int f1y9b) =
            fp12Frob1(y90,y91,y92,y93,y94,y95,y96,y97,y98,y99,y9a,y9b);
        (int y8y40,int y8y41,int y8y42,int y8y43,int y8y44,int y8y45,int y8y46,int y8y47,int y8y48,int y8y49,int y8y4a,int y8y4b) =
            fp12Mul(y80,y81,y82,y83,y84,y85,y86,y87,y88,y89,y8a,y8b, y40,y41,y42,y43,y44,y45,y46,y47,y48,y49,y4a,y4b);
        (int y8y4r0,int y8y4r1,int y8y4r2,int y8y4r3,int y8y4r4,int y8y4r5,int y8y4r6,int y8y4r7,int y8y4r8,int y8y4r9,int y8y4ra,int y8y4rb) =
            fp12Mul(y8y40,y8y41,y8y42,y8y43,y8y44,y8y45,y8y46,y8y47,y8y48,y8y49,y8y4a,y8y4b, R0,R1,R2,R3,R4,R5,R6,R7,R8,R9,R10,R11);
        (int inn0,int inn1,int inn2,int inn3,int inn4,int inn5,int inn6,int inn7,int inn8,int inn9,int inna,int innb) =
            fp12Mul(f1y90,f1y91,f1y92,f1y93,f1y94,f1y95,f1y96,f1y97,f1y98,f1y99,f1y9a,f1y9b, y8y4r0,y8y4r1,y8y4r2,y8y4r3,y8y4r4,y8y4r5,y8y4r6,y8y4r7,y8y4r8,y8y4r9,y8y4ra,y8y4rb);
        (int RT0,int RT1,int RT2,int RT3,int RT4,int RT5,int RT6,int RT7,int RT8,int RT9,int RTa,int RTb) =
            fp12Mul(f2y80,f2y81,f2y82,f2y83,f2y84,f2y85,f2y86,f2y87,f2y88,f2y89,f2y8a,f2y8b, inn0,inn1,inn2,inn3,inn4,inn5,inn6,inn7,inn8,inn9,inna,innb);
        // result = left * right
        (int O0,int O1,int O2,int O3,int O4,int O5,int O6,int O7,int O8,int O9,int O10,int O11) =
            fp12Mul(L0,L1,L2,L3,L4,L5,L6,L7,L8,L9,La,Lb, RT0,RT1,RT2,RT3,RT4,RT5,RT6,RT7,RT8,RT9,RTa,RTb);
        return O0,O1,O2,O3,O4,O5,O6,O7,O8,O9,O10,O11;
    }


    // ---- Miller-loop additions ----
    function fp2MulByB(int a0, int a1) returns (int, int) {
        (int r0, int r1) = fp2Mul(a0, a1,
            19485874751759354771024239261021720505790618469301721065564631296452457478373,
            266929791119991161246907387137283842545076965332900288569378510910307636690);
        return r0, r1;
    }

    function fp2Half(int a0, int a1) returns (int, int) {
        return mulFp(a0, 10944121435919637611123202872628637544348155578648911831344518947322613104292),
               mulFp(a1, 10944121435919637611123202872628637544348155578648911831344518947322613104292);
    }

    function fp6Mul01(int c0a,int c0b,int c1a,int c1b,int c2a,int c2b, int b0a,int b0b,int b1a,int b1b) returns (int,int,int,int,int,int) {
        (int t0a,int t0b) = fp2Mul(c0a, c0b, b0a, b0b);
        (int t1a,int t1b) = fp2Mul(c1a, c1b, b1a, b1b);
        (int s12a,int s12b) = fp2Add(c1a, c1b, c2a, c2b);
        (int m12a,int m12b) = fp2Mul(s12a, s12b, b1a, b1b);
        (int u0a,int u0b) = fp2Sub(m12a, m12b, t1a, t1b);
        (int xu0a,int xu0b) = fp2MulXi(u0a, u0b);
        (int r0a,int r0b) = fp2Add(xu0a, xu0b, t0a, t0b);
        (int sba,int sbb) = fp2Add(b0a, b0b, b1a, b1b);
        (int sca,int scb) = fp2Add(c0a, c0b, c1a, c1b);
        (int m1a,int m1b) = fp2Mul(sba, sbb, sca, scb);
        (int u1a,int u1b) = fp2Sub(m1a, m1b, t0a, t0b);
        (int r1a,int r1b) = fp2Sub(u1a, u1b, t1a, t1b);
        (int s02a,int s02b) = fp2Add(c0a, c0b, c2a, c2b);
        (int m2a,int m2b) = fp2Mul(s02a, s02b, b0a, b0b);
        (int u2a,int u2b) = fp2Sub(m2a, m2b, t0a, t0b);
        (int r2a,int r2b) = fp2Add(u2a, u2b, t1a, t1b);
        return r0a, r0b, r1a, r1b, r2a, r2b;
    }

    function fp12Sqr(
        int A0,int A1,int A2,int A3,int A4,int A5, int A6,int A7,int A8,int A9,int A10,int A11
    ) returns (int,int,int,int,int,int,int,int,int,int,int,int) {
        (int C0,int C1,int C2,int C3,int C4,int C5,int C6,int C7,int C8,int C9,int C10,int C11) =
            fp12Mul(A0,A1,A2,A3,A4,A5,A6,A7,A8,A9,A10,A11, A0,A1,A2,A3,A4,A5,A6,A7,A8,A9,A10,A11);
        return C0,C1,C2,C3,C4,C5,C6,C7,C8,C9,C10,C11;
    }

    function mul034(
        int F0,int F1,int F2,int F3,int F4,int F5, int F6,int F7,int F8,int F9,int F10,int F11,
        int o0a,int o0b, int o3a,int o3b, int o4a,int o4b
    ) returns (int,int,int,int,int,int,int,int,int,int,int,int) {
        (int A0,int A1) = fp2Mul(F0, F1, o0a, o0b);
        (int A2,int A3) = fp2Mul(F2, F3, o0a, o0b);
        (int A4,int A5) = fp2Mul(F4, F5, o0a, o0b);
        (int B0,int B1,int B2,int B3,int B4,int B5) = fp6Mul01(F6,F7,F8,F9,F10,F11, o3a,o3b, o4a,o4b);
        (int S0,int S1,int S2,int S3,int S4,int S5) = fp6Add(F0,F1,F2,F3,F4,F5, F6,F7,F8,F9,F10,F11);
        (int qa,int qb) = fp2Add(o0a, o0b, o3a, o3b);
        (int G0,int G1,int G2,int G3,int G4,int G5) = fp6Mul01(S0,S1,S2,S3,S4,S5, qa,qb, o4a,o4b);
        (int VB0,int VB1,int VB2,int VB3,int VB4,int VB5) = fp6MulByV(B0,B1,B2,B3,B4,B5);
        (int C0,int C1,int C2,int C3,int C4,int C5) = fp6Add(VB0,VB1,VB2,VB3,VB4,VB5, A0,A1,A2,A3,A4,A5);
        (int AB0,int AB1,int AB2,int AB3,int AB4,int AB5) = fp6Add(A0,A1,A2,A3,A4,A5, B0,B1,B2,B3,B4,B5);
        (int C6,int C7,int C8,int C9,int C10,int C11) = fp6Sub(G0,G1,G2,G3,G4,G5, AB0,AB1,AB2,AB3,AB4,AB5);
        return C0,C1,C2,C3,C4,C5,C6,C7,C8,C9,C10,C11;
    }

    function line(
        int F0,int F1,int F2,int F3,int F4,int F5,int F6,int F7,int F8,int F9,int F10,int F11,
        int c0a,int c0b,int c1a,int c1b,int c2a,int c2b, int Px, int Py
    ) returns (int,int,int,int,int,int,int,int,int,int,int,int) {
        int o0a = mulFp(c2a, Py);
        int o0b = mulFp(c2b, Py);
        int o3a = mulFp(c1a, Px);
        int o3b = mulFp(c1b, Px);
        (int r0,int r1,int r2,int r3,int r4,int r5,int r6,int r7,int r8,int r9,int r10,int r11) =
            mul034(F0,F1,F2,F3,F4,F5,F6,F7,F8,F9,F10,F11, o0a,o0b, o3a,o3b, c0a,c0b);
        return r0,r1,r2,r3,r4,r5,r6,r7,r8,r9,r10,r11;
    }

    function pointDouble(int Xa,int Xb,int Ya,int Yb,int Za,int Zb)
        returns (int,int,int,int,int,int, int,int,int,int,int,int) {
        (int t0a,int t0b) = fp2Sqr(Ya, Yb);
        (int t1a,int t1b) = fp2Sqr(Za, Zb);
        (int s1a,int s1b) = fp2Scale(t1a, t1b, 3);
        (int t2a,int t2b) = fp2MulByB(s1a, s1b);
        (int t3a,int t3b) = fp2Scale(t2a, t2b, 3);
        (int yza,int yzb) = fp2Add(Ya, Yb, Za, Zb);
        (int sq_a,int sq_b) = fp2Sqr(yza, yzb);
        (int u4a,int u4b) = fp2Sub(sq_a, sq_b, t1a, t1b);
        (int t4a,int t4b) = fp2Sub(u4a, u4b, t0a, t0b);
        (int c0a,int c0b) = fp2Sub(t2a, t2b, t0a, t0b);
        (int rxq_a,int rxq_b) = fp2Sqr(Xa, Xb);
        (int c1a,int c1b) = fp2Scale(rxq_a, rxq_b, 3);
        (int c2a,int c2b) = fp2Neg(t4a, t4b);
        (int da,int db) = fp2Sub(t0a, t0b, t3a, t3b);
        (int dxa,int dxb) = fp2Mul(da, db, Xa, Xb);
        (int dxya,int dxyb) = fp2Mul(dxa, dxb, Ya, Yb);
        (int nxa,int nxb) = fp2Half(dxya, dxyb);
        (int sa,int sb) = fp2Add(t0a, t0b, t3a, t3b);
        (int sha,int shb) = fp2Half(sa, sb);
        (int sh2a,int sh2b) = fp2Sqr(sha, shb);
        (int t2sa,int t2sb) = fp2Sqr(t2a, t2b);
        (int t2s3a,int t2s3b) = fp2Scale(t2sa, t2sb, 3);
        (int nya,int nyb) = fp2Sub(sh2a, sh2b, t2s3a, t2s3b);
        (int nza,int nzb) = fp2Mul(t0a, t0b, t4a, t4b);
        return c0a,c0b,c1a,c1b,c2a,c2b, nxa,nxb,nya,nyb,nza,nzb;
    }

    function pointAdd(int Xa,int Xb,int Ya,int Yb,int Za,int Zb, int Qxa,int Qxb,int Qya,int Qyb)
        returns (int,int,int,int,int,int, int,int,int,int,int,int) {
        (int qyz_a,int qyz_b) = fp2Mul(Qya, Qyb, Za, Zb);
        (int t0a,int t0b) = fp2Sub(Ya, Yb, qyz_a, qyz_b);
        (int qxz_a,int qxz_b) = fp2Mul(Qxa, Qxb, Za, Zb);
        (int t1a,int t1b) = fp2Sub(Xa, Xb, qxz_a, qxz_b);
        (int t0qx_a,int t0qx_b) = fp2Mul(t0a, t0b, Qxa, Qxb);
        (int t1qy_a,int t1qy_b) = fp2Mul(t1a, t1b, Qya, Qyb);
        (int c0a,int c0b) = fp2Sub(t0qx_a, t0qx_b, t1qy_a, t1qy_b);
        (int c1a,int c1b) = fp2Neg(t0a, t0b);
        int c2a = t1a;
        int c2b = t1b;
        (int t2a,int t2b) = fp2Sqr(t1a, t1b);
        (int t3a,int t3b) = fp2Mul(t2a, t2b, t1a, t1b);
        (int t4a,int t4b) = fp2Mul(t2a, t2b, Xa, Xb);
        (int t42a,int t42b) = fp2Scale(t4a, t4b, 2);
        (int d35a,int d35b) = fp2Sub(t3a, t3b, t42a, t42b);
        (int t0sa,int t0sb) = fp2Sqr(t0a, t0b);
        (int t0sza,int t0szb) = fp2Mul(t0sa, t0sb, Za, Zb);
        (int t5a,int t5b) = fp2Add(d35a, d35b, t0sza, t0szb);
        (int nxa,int nxb) = fp2Mul(t1a, t1b, t5a, t5b);
        (int d45a,int d45b) = fp2Sub(t4a, t4b, t5a, t5b);
        (int d45t0a,int d45t0b) = fp2Mul(d45a, d45b, t0a, t0b);
        (int t3rya,int t3ryb) = fp2Mul(t3a, t3b, Ya, Yb);
        (int nya,int nyb) = fp2Sub(d45t0a, d45t0b, t3rya, t3ryb);
        (int nza,int nzb) = fp2Mul(Za, Zb, t3a, t3b);
        return c0a,c0b,c1a,c1b,c2a,c2b, nxa,nxb,nya,nyb,nza,nzb;
    }

    function psi(int xa,int xb,int ya,int yb) returns (int,int,int,int) {
        (int cxa,int cxb) = fp2Conj(xa, xb);
        (int pxa,int pxb) = fp2Mul(cxa, cxb,
            21575463638280843010398324269430826099269044274347216827212613867836435027261,
            10307601595873709700152284273816112264069230130616436755625194854815875713954);
        (int cya,int cyb) = fp2Conj(ya, yb);
        (int pya,int pyb) = fp2Mul(cya, cyb,
            2821565182194536844548159561693502659359617185244120367078079554186484126554,
            3505843767911556378687030309984248845540243509899259641013678093033130930403);
        return pxa, pxb, pya, pyb;
    }

    function millerSingle(int Qxa,int Qxb,int Qya,int Qyb, int Px, int Py)
        returns (int,int,int,int,int,int,int,int,int,int,int,int) {
        // f = ONE
        int F0=1; int F1=0; int F2=0; int F3=0; int F4=0; int F5=0;
        int F6=0; int F7=0; int F8=0; int F9=0; int F10=0; int F11=0;
        // R = (Q, 1)
        int Rxa=Qxa; int Rxb=Qxb; int Rya=Qya; int Ryb=Qyb; int Rza=1; int Rzb=0;

        for (int k = 0; k < 65; k = k + 1) {
            // f = f^2
            (int q0,int q1,int q2,int q3,int q4,int q5,int q6,int q7,int q8,int q9,int q10,int q11) =
                fp12Sqr(F0,F1,F2,F3,F4,F5,F6,F7,F8,F9,F10,F11);
            F0=q0; F1=q1; F2=q2; F3=q3; F4=q4; F5=q5; F6=q6; F7=q7; F8=q8; F9=q9; F10=q10; F11=q11;
            // double + line
            (int dc0,int dc1,int dc2,int dc3,int dc4,int dc5, int dx0,int dx1,int dx2,int dx3,int dx4,int dx5) =
                pointDouble(Rxa,Rxb,Rya,Ryb,Rza,Rzb);
            Rxa=dx0; Rxb=dx1; Rya=dx2; Ryb=dx3; Rza=dx4; Rzb=dx5;
            (int g0,int g1,int g2,int g3,int g4,int g5,int g6,int g7,int g8,int g9,int g10,int g11) =
                line(F0,F1,F2,F3,F4,F5,F6,F7,F8,F9,F10,F11, dc0,dc1,dc2,dc3,dc4,dc5, Px, Py);
            F0=g0; F1=g1; F2=g2; F3=g3; F4=g4; F5=g5; F6=g6; F7=g7; F8=g8; F9=g9; F10=g10; F11=g11;
            // conditional add + line (NAF digit nonzero)
            int nz = (3045737938581365386 >> k) % 2;
            if (nz == 1) {
                int neg = (162306075919524482 >> k) % 2;
                int uya = Qya;
                int uyb = Qyb;
                if (neg == 1) { (int na,int nb) = fp2Neg(Qya, Qyb); uya=na; uyb=nb; }
                (int ac0,int ac1,int ac2,int ac3,int ac4,int ac5, int ax0,int ax1,int ax2,int ax3,int ax4,int ax5) =
                    pointAdd(Rxa,Rxb,Rya,Ryb,Rza,Rzb, Qxa,Qxb,uya,uyb);
                Rxa=ax0; Rxb=ax1; Rya=ax2; Ryb=ax3; Rza=ax4; Rzb=ax5;
                (int h0,int h1,int h2,int h3,int h4,int h5,int h6,int h7,int h8,int h9,int h10,int h11) =
                    line(F0,F1,F2,F3,F4,F5,F6,F7,F8,F9,F10,F11, ac0,ac1,ac2,ac3,ac4,ac5, Px, Py);
                F0=h0; F1=h1; F2=h2; F3=h3; F4=h4; F5=h5; F6=h6; F7=h7; F8=h8; F9=h9; F10=h10; F11=h11;
            }
        }

        // postPrecompute: Q1 = psi(Q), add (+y); Q2 = psi(Q1), add (-y)
        (int q1xa,int q1xb,int q1ya,int q1yb) = psi(Qxa,Qxb,Qya,Qyb);
        (int bc0,int bc1,int bc2,int bc3,int bc4,int bc5, int bx0,int bx1,int bx2,int bx3,int bx4,int bx5) =
            pointAdd(Rxa,Rxb,Rya,Ryb,Rza,Rzb, q1xa,q1xb,q1ya,q1yb);
        Rxa=bx0; Rxb=bx1; Rya=bx2; Ryb=bx3; Rza=bx4; Rzb=bx5;
        (int i0,int i1,int i2,int i3,int i4,int i5,int i6,int i7,int i8,int i9,int i10,int i11) =
            line(F0,F1,F2,F3,F4,F5,F6,F7,F8,F9,F10,F11, bc0,bc1,bc2,bc3,bc4,bc5, Px, Py);
        F0=i0; F1=i1; F2=i2; F3=i3; F4=i4; F5=i5; F6=i6; F7=i7; F8=i8; F9=i9; F10=i10; F11=i11;

        (int q2xa,int q2xb,int q2ya,int q2yb) = psi(q1xa,q1xb,q1ya,q1yb);
        (int q2nya,int q2nyb) = fp2Neg(q2ya, q2yb);
        (int cc0,int cc1,int cc2,int cc3,int cc4,int cc5, int cx0,int cx1,int cx2,int cx3,int cx4,int cx5) =
            pointAdd(Rxa,Rxb,Rya,Ryb,Rza,Rzb, q2xa,q2xb,q2nya,q2nyb);
        Rxa=cx0; Rxb=cx1; Rya=cx2; Ryb=cx3; Rza=cx4; Rzb=cx5; // consume new R (unused after final line)
        (int j0,int j1,int j2,int j3,int j4,int j5,int j6,int j7,int j8,int j9,int j10,int j11) =
            line(F0,F1,F2,F3,F4,F5,F6,F7,F8,F9,F10,F11, cc0,cc1,cc2,cc3,cc4,cc5, Px, Py);

        return j0,j1,j2,j3,j4,j5,j6,j7,j8,j9,j10,j11;
    }


    // ---- G1 (Fp) scalar mult for on-chain vk_x = IC0 + in0*IC1 + in1*IC2 ----
    function sqrFp(int x) returns (int) { return (x * x) % 21888242871839275222246405745257275088696311157297823662689037894645226208583; }
    function jacDoubleG1(int x, int y, int z) returns (int, int, int) {
        int a = sqrFp(x);
        int b = sqrFp(y);
        int c = sqrFp(b);
        int d = mulFp(2, subFp(subFp(sqrFp(addFp(x, b)), a), c));
        int e = mulFp(3, a);
        int f = sqrFp(e);
        int nx = subFp(f, mulFp(2, d));
        int ny = subFp(mulFp(e, subFp(d, nx)), mulFp(8, c));
        int nz = mulFp(2, mulFp(y, z));
        return nx, ny, nz;
    }
    function jacAddG1(int aX, int aY, int aZ, int bX, int bY, int bZ) returns (int, int, int) {
        int rx = bX;
        int ry = bY;
        int rz = bZ;
        if (aZ != 0) {
            int z1z1 = sqrFp(aZ);
            int z2z2 = sqrFp(bZ);
            int u1 = mulFp(aX, z2z2);
            int u2 = mulFp(bX, z1z1);
            int s1 = mulFp(mulFp(aY, bZ), z2z2);
            int s2 = mulFp(mulFp(bY, aZ), z1z1);
            if (u1 == u2 && s1 == s2) {
                int da = sqrFp(aX);
                int db = sqrFp(aY);
                int dc = sqrFp(db);
                int dd = mulFp(2, subFp(subFp(sqrFp(addFp(aX, db)), da), dc));
                int de = mulFp(3, da);
                int df = sqrFp(de);
                int dnx = subFp(df, mulFp(2, dd));
                int dny = subFp(mulFp(de, subFp(dd, dnx)), mulFp(8, dc));
                int dnz = mulFp(2, mulFp(aY, aZ));
                rx = dnx; ry = dny; rz = dnz;
            } else {
                int h = subFp(u2, u1);
                int i2 = sqrFp(mulFp(2, h));
                int jj = mulFp(h, i2);
                int rr = mulFp(2, subFp(s2, s1));
                int vv = mulFp(u1, i2);
                int anx = subFp(subFp(sqrFp(rr), jj), mulFp(2, vv));
                int any = subFp(mulFp(rr, subFp(vv, anx)), mulFp(2, mulFp(s1, jj)));
                int anz = mulFp(subFp(subFp(sqrFp(addFp(aZ, bZ)), z1z1), z2z2), h);
                rx = anx; ry = any; rz = anz;
            }
        }
        return rx, ry, rz;
    }
    // scalar * (bx,by affine) -> Jacobian (LSB-first double-and-add, base doubling)
    function g1ScalarMul(int scalar, int bx, int by) returns (int, int, int) {
        int rX = 0; int rY = 1; int rZ = 0;
        int cX = bx; int cY = by; int cZ = 1;
        for (int i = 0; i < 254; i = i + 1) {
            if (((scalar >> i) % 2) == 1) {
                (int ax, int ay, int az) = jacAddG1(rX, rY, rZ, cX, cY, cZ);
                rX = ax; rY = ay; rZ = az;
            }
            if (cZ != 0 && cY != 0) {
                (int dx, int dy, int dz) = jacDoubleG1(cX, cY, cZ);
                cX = dx; cY = dy; cZ = dz;
            }
        }
        return rX, rY, rZ;
    }
    function jacToAffine(int x, int y, int z) returns (int, int) {
        int zInv = inverseFp(z);
        int zInv2 = sqrFp(zInv);
        int zInv3 = mulFp(zInv2, zInv);
        return mulFp(x, zInv2), mulFp(y, zInv3);
    }

    // Full Groth16 verification: compute vk_x on-chain from the public inputs,
    // then require the pairing product == 1. VK (alpha,beta,gamma,delta,IC) is
    // hardcoded for the committed instance; proof (A,B,C) and public inputs
    // (in0,in1) are runtime. This is the SOUND singleton verifier.
    function spend(
        int Ax, int Ay, int Bxa, int Bxb, int Bya, int Byb, int Cx, int Cy,
        int in0, int in1
    ) {
        // vk_x = IC0 + in0*IC1 + in1*IC2
        (int r1x, int r1y, int r1z) = g1ScalarMul(in0,
            9269869340829791644953940526610795845982127221382366381974052273854848284744,
            12340830433822638848259976740304056841548514693917037023437897137808450264577);
        (int r2x, int r2y, int r2z) = g1ScalarMul(in1,
            6442706084407552401539720969529928260622245802604045626376932056434206076947,
            13805589277496019078136496656829548863642318729315912795941464570275337353000);
        (int a1x, int a1y, int a1z) = jacAddG1(
            15723390722547469201346605927630336729729463607293657950235977012003655267936,
            14617976463853845616027311884626760527376622737858716767193455441349641383825, 1,
            r1x, r1y, r1z);
        (int vx, int vy, int vz) = jacAddG1(a1x, a1y, a1z, r2x, r2y, r2z);
        (int vkxX, int vkxY) = jacToAffine(vx, vy, vz);

        // e(-A,B) * e(alpha,beta) * e(vk_x,gamma) * e(C,delta) == 1
        int nAy = subFp(0, Ay);
        (int m1_0,int m1_1,int m1_2,int m1_3,int m1_4,int m1_5,int m1_6,int m1_7,int m1_8,int m1_9,int m1_10,int m1_11) =
            millerSingle(Bxa, Bxb, Bya, Byb, Ax, nAy);
        (int m2_0,int m2_1,int m2_2,int m2_3,int m2_4,int m2_5,int m2_6,int m2_7,int m2_8,int m2_9,int m2_10,int m2_11) =
            millerSingle(
                17467917077997409920481960112226002748883030164933060982083570835869719819168,
                9543924542455805865677785465159349894279659454147026211356195301797094705807,
                20459688264762308310588269661274938525104694421730310554970214541176968393385,
                19465560217230762055900455536522601853894771406309777885817297488125148793229,
                14344921588710038019110518519527661247161785735962037005430040319326557952203,
                1404059666412774300404055719909964693738831005230889414572223472408856431918);
        (int m3_0,int m3_1,int m3_2,int m3_3,int m3_4,int m3_5,int m3_6,int m3_7,int m3_8,int m3_9,int m3_10,int m3_11) =
            millerSingle(
                13700863412905423759250606799218875849166292978636329233814994817818554546431,
                21761028412726985313317130874134828290145951226051416150723277301116006118078,
                21547676276454546410296902538495425432829390494566673627605034971294784210249,
                6398877257285935365249802814125273995578953055511620955996813742572019651748,
                vkxX, vkxY);
        (int m4_0,int m4_1,int m4_2,int m4_3,int m4_4,int m4_5,int m4_6,int m4_7,int m4_8,int m4_9,int m4_10,int m4_11) =
            millerSingle(
                15825285363846036862295217228464959249112247579247978462621447842724817286232,
                3543600181522862329564888283473085279940669956506060026762005346996341806108,
                21514667205241674535457714632061047258097217169787877277363751636045743019390,
                10670741793215758088800930336726579942257175283397977169474518534600570072949,
                Cx, Cy);
        (int ab0,int ab1,int ab2,int ab3,int ab4,int ab5,int ab6,int ab7,int ab8,int ab9,int ab10,int ab11) =
            fp12Mul(m1_0,m1_1,m1_2,m1_3,m1_4,m1_5,m1_6,m1_7,m1_8,m1_9,m1_10,m1_11, m2_0,m2_1,m2_2,m2_3,m2_4,m2_5,m2_6,m2_7,m2_8,m2_9,m2_10,m2_11);
        (int abc0,int abc1,int abc2,int abc3,int abc4,int abc5,int abc6,int abc7,int abc8,int abc9,int abc10,int abc11) =
            fp12Mul(ab0,ab1,ab2,ab3,ab4,ab5,ab6,ab7,ab8,ab9,ab10,ab11, m3_0,m3_1,m3_2,m3_3,m3_4,m3_5,m3_6,m3_7,m3_8,m3_9,m3_10,m3_11);
        (int bnd0,int bnd1,int bnd2,int bnd3,int bnd4,int bnd5,int bnd6,int bnd7,int bnd8,int bnd9,int bnd10,int bnd11) =
            fp12Mul(abc0,abc1,abc2,abc3,abc4,abc5,abc6,abc7,abc8,abc9,abc10,abc11, m4_0,m4_1,m4_2,m4_3,m4_4,m4_5,m4_6,m4_7,m4_8,m4_9,m4_10,m4_11);
        (int o0,int o1,int o2,int o3,int o4,int o5,int o6,int o7,int o8,int o9,int o10,int o11) =
            finalExp(bnd0,bnd1,bnd2,bnd3,bnd4,bnd5,bnd6,bnd7,bnd8,bnd9,bnd10,bnd11);
        require(o0==1); require(o1==0); require(o2==0); require(o3==0); require(o4==0); require(o5==0);
        require(o6==0); require(o7==0); require(o8==0); require(o9==0); require(o10==0); require(o11==0);
    }
}
