            }
            if (bZ != 0 && bY != 0) {
                int a = sqrFp(bX);
                int b = sqrFp(bY);
                int c = sqrFp(b);
                int dd = mulFp(2, subFp(subFp(sqrFp(addFp(bX, b)), a), c));
