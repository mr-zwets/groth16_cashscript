function fp4Square(int a0,int a1,int b0,int b1) returns (int,int,int,int) {
    (int a2a,int a2b) = fp2Sqr(a0, a1);
    (int b2a,int b2b) = fp2Sqr(b0, b1);
    (int xbi0,int xbi1) = fp2MulXi(b2a, b2b, 1);
    (int f0,int f1) = fp2Add(xbi0, xbi1, a2a, a2b);
    (int aba,int abb) = fp2Add(a0, a1, b0, b1);
    (int absqa,int absqb) = fp2Sqr(aba, abb);
    (int sub1a,int sub1b) = fp2Sub(absqa, absqb, a2a, a2b, 1);
    (int s0,int s1) = fp2Sub(sub1a, sub1b, b2a, b2b, 1);
    return f0, f1, s0, s1;
}

function cycSqr(int A0,int A1,int A2,int A3,int A4,int A5, int A6,int A7,int A8,int A9,int A10,int A11)
    returns (int,int,int,int,int,int,int,int,int,int,int,int) {
    (int t3a,int t3b,int t4a,int t4b) = fp4Square(A0,A1, A8,A9);
    (int t5a,int t5b,int t6a,int t6b) = fp4Square(A6,A7, A4,A5);
    (int t7a,int t7b,int t8a,int t8b) = fp4Square(A2,A3, A10,A11);
    (int t9a,int t9b) = fp2MulXi(t8a, t8b, 3);
    (int z0a,int z0b) = fp2Sub(t3a, t3b, A0, A1, 62);   (int o0a,int o0b) = fp2Add(mulFp(z0a,2), mulFp(z0b,2), t3a, t3b);
    (int z1a,int z1b) = fp2Sub(t5a, t5b, A2, A3, 62);   (int o1a,int o1b) = fp2Add(mulFp(z1a,2), mulFp(z1b,2), t5a, t5b);
    (int z2a,int z2b) = fp2Sub(t7a, t7b, A4, A5, 62);   (int o2a,int o2b) = fp2Add(mulFp(z2a,2), mulFp(z2b,2), t7a, t7b);
    (int z3a,int z3b) = fp2Add(t9a, t9b, A6, A7);   (int o3a,int o3b) = fp2Add(mulFp(z3a,2), mulFp(z3b,2), t9a, t9b);
    (int z4a,int z4b) = fp2Add(t4a, t4b, A8, A9);   (int o4a,int o4b) = fp2Add(mulFp(z4a,2), mulFp(z4b,2), t4a, t4b);
    (int z5a,int z5b) = fp2Add(t6a, t6b, A10, A11); (int o5a,int o5b) = fp2Add(mulFp(z5a,2), mulFp(z5b,2), t6a, t6b);
    return o0a,o0b,o1a,o1b,o2a,o2b,o3a,o3b,o4a,o4b,o5a,o5b;
}

function mul014(
    int F0,int F1,int F2,int F3,int F4,int F5, int F6,int F7,int F8,int F9,int F10,int F11,
    int o0a,int o0b, int o1a,int o1b, int o4a,int o4b
) returns (int,int,int,int,int,int,int,int,int,int,int,int) {
    (int T0,int T1,int T2,int T3,int T4,int T5) = fp6Mul01(F0,F1,F2,F3,F4,F5, o0a,o0b, o1a,o1b);
    (int U0,int U1,int U2,int U3,int U4,int U5) = fp6Mul1(F6,F7,F8,F9,F10,F11, o4a,o4b);
    (int V0,int V1,int V2,int V3,int V4,int V5) = fp6MulByV(U0,U1,U2,U3,U4,U5, 3);
    (int C0,int C1,int C2,int C3,int C4,int C5) = fp6Add(V0,V1,V2,V3,V4,V5, T0,T1,T2,T3,T4,T5);
    (int S0,int S1,int S2,int S3,int S4,int S5) = fp6Add(F6,F7,F8,F9,F10,F11, F0,F1,F2,F3,F4,F5);
    (int qa,int qb) = fp2Add(o1a, o1b, o4a, o4b);
    (int G0,int G1,int G2,int G3,int G4,int G5) = fp6Mul01(S0,S1,S2,S3,S4,S5, o0a,o0b, qa,qb);
    (int H0,int H1,int H2,int H3,int H4,int H5) = fp6Sub(G0,G1,G2,G3,G4,G5, T0,T1,T2,T3,T4,T5, 14);
    (int C6,int C7,int C8,int C9,int C10,int C11) = fp6Sub(H0,H1,H2,H3,H4,H5, U0,U1,U2,U3,U4,U5, 5);
    return C0,C1,C2,C3,C4,C5,C6,C7,C8,C9,C10,C11;
}

function line(
    int F0,int F1,int F2,int F3,int F4,int F5,int F6,int F7,int F8,int F9,int F10,int F11,
    int c0a,int c0b,int c1a,int c1b,int c2a,int c2b, int Px, int Py
) returns (int,int,int,int,int,int,int,int,int,int,int,int) {
    int o1a = mulFp(c1a, Px);
    int o1b = mulFp(c1b, Px);
    int o4a = mulFp(c2a, Py);
    int o4b = mulFp(c2b, Py);
    (int r0,int r1,int r2,int r3,int r4,int r5,int r6,int r7,int r8,int r9,int r10,int r11) =
        mul014(F0,F1,F2,F3,F4,F5,F6,F7,F8,F9,F10,F11, c0a,c0b, o1a,o1b, o4a,o4b);
    return r0,r1,r2,r3,r4,r5,r6,r7,r8,r9,r10,r11;
}

// Identity-complete G1 line fold for the BLS M-twist. Runtime G1 points use
// u=-x/(2y), v=-1/(2y) and (0,0) for infinity. Multiplying the raw mul014 line by
// -2v/(W*V) yields sparse positions (0,4,5):
//   c2 - (2*c0*v/xi)*W*V - (2*c1*u/xi)*W*V^2, xi=1+i.
// The removed factor is in the final-exponent kernel. At infinity, every accepted
// effective G2 walk leaves a nonzero Fp2 c2, which is also killed by that exponent.
function lineUnitScaled(
    int F0,int F1,int F2,int F3,int F4,int F5,int F6,int F7,int F8,int F9,int F10,int F11,
    int c0a,int c0b,int c1a,int c1b,int c2a,int c2b, int u, int v
) returns (int,int,int,int,int,int,int,int,int,int,int,int) {
    int o4a = mulFp(subFp(0, addFp(c0a, c0b), 128), v);
    int o4b = mulFp(subFp(c0a, c0b, 64), v);
    int o5a = mulFp(subFp(0, addFp(c1a, c1b), 128), u);
    int o5b = mulFp(subFp(c1a, c1b, 64), u);
    // Sparse Fp12 multiply by (c2,0,0) + (0,o4,o5)W. This is one
    // Fp2 product more than mul014, avoiding a generic dense multiply.
    (int t0a,int t0b,int t1a,int t1b,int t2a,int t2b) =
        fp6MulByFp2(F0,F1,F2,F3,F4,F5, c2a,c2b);

    (int p1a,int p1b) = fp2Mul(F8,F9, o4a,o4b);
    (int p2a,int p2b) = fp2Mul(F10,F11, o5a,o5b);
    (int s12a,int s12b) = fp2Add(F8,F9,F10,F11);
    (int so12a,int so12b) = fp2Add(o4a,o4b,o5a,o5b);
    (int pcrossa,int pcrossb) = fp2Mul(s12a,s12b,so12a,so12b);
    (int dcrossa,int dcrossb) = fp2Sub(pcrossa,pcrossb,p1a,p1b,3);
    (int crossa,int crossb) = fp2Sub(dcrossa,dcrossb,p2a,p2b,3);
    (int q0a,int q0b) = fp2MulXi(crossa,crossb,9);
    (int s01a,int s01b) = fp2Add(F6,F7,F8,F9);
    (int ps01a,int ps01b) = fp2Mul(s01a,s01b,o4a,o4b);
    (int b0s1a,int b0s1b) = fp2Sub(ps01a,ps01b,p1a,p1b,3);
    (int xp2a,int xp2b) = fp2MulXi(p2a,p2b,3);
    (int q1a,int q1b) = fp2Add(b0s1a,b0s1b,xp2a,xp2b);
    (int s02a,int s02b) = fp2Add(F6,F7,F10,F11);
    (int ps02a,int ps02b) = fp2Mul(s02a,s02b,o5a,o5b);
    (int b0s2a,int b0s2b) = fp2Sub(ps02a,ps02b,p2a,p2b,3);
    (int q2a,int q2b) = fp2Add(b0s2a,b0s2b,p1a,p1b);

    (int vq0,int vq1,int vq2,int vq3,int vq4,int vq5) = fp6MulByV(q0a,q0b,q1a,q1b,q2a,q2b,9);
    (int C0,int C1,int C2,int C3,int C4,int C5) = fp6Add(t0a,t0b,t1a,t1b,t2a,t2b, vq0,vq1,vq2,vq3,vq4,vq5);
    (int sf0,int sf1,int sf2,int sf3,int sf4,int sf5) = fp6Add(F0,F1,F2,F3,F4,F5, F6,F7,F8,F9,F10,F11);
    (int pr0,int pr1,int pr2,int pr3,int pr4,int pr5) = fp6Mul(sf0,sf1,sf2,sf3,sf4,sf5, c2a,c2b,o4a,o4b,o5a,o5b);
    (int d0,int d1,int d2,int d3,int d4,int d5) = fp6Sub(pr0,pr1,pr2,pr3,pr4,pr5, t0a,t0b,t1a,t1b,t2a,t2b,3);
    (int C6,int C7,int C8,int C9,int C10,int C11) = fp6Sub(d0,d1,d2,d3,d4,d5, q0a,q0b,q1a,q1b,q2a,q2b,17);
    return C0,C1,C2,C3,C4,C5,C6,C7,C8,C9,C10,C11;
}

// Exact direct product by c2 + (o4*V+o5*V^2)W. The internal Fp6 products stay
// unreduced and only the twelve returned limbs are normalized.
function lineUnitScaledRaw(
    int F0,int F1,int F2,int F3,int F4,int F5,int F6,int F7,int F8,int F9,int F10,int F11,
    int c0a,int c0b,int c1a,int c1b,int c2a,int c2b, int u, int v
) returns (int,int,int,int,int,int,int,int,int,int,int,int) {
    int o4a = mulFp(subFp(0, addFp(c0a, c0b), 128), v);
    int o4b = mulFp(subFp(c0a, c0b, 64), v);
    int o5a = mulFp(subFp(0, addFp(c1a, c1b), 128), u);
    int o5b = mulFp(subFp(c1a, c1b, 64), u);
    (int xa0,int xa1) = fp2MulRaw(F0,F1,c2a,c2b);
    (int xa2,int xa3) = fp2MulRaw(F2,F3,c2a,c2b);
    (int xa4,int xa5) = fp2MulRaw(F4,F5,c2a,c2b);
    (int ya0,int ya1) = fp2MulRaw(F6,F7,c2a,c2b);
    (int ya2,int ya3) = fp2MulRaw(F8,F9,c2a,c2b);
    (int ya4,int ya5) = fp2MulRaw(F10,F11,c2a,c2b);
    (int yt0,int yt1,int yt2,int yt3,int yt4,int yt5) =
        fp6Mul12Raw(F6,F7,F8,F9,F10,F11,o4a,o4b,o5a,o5b);
    (int xt0,int xt1,int xt2,int xt3,int xt4,int xt5) =
        fp6Mul12Raw(F0,F1,F2,F3,F4,F5,o4a,o4b,o5a,o5b);
    int p = 4002409555221667393417789825735904156556882819939007885332058136124031650490837864442687629129015664037894272559787;
    int rawBias = 1231562419205459752070235395775242614848400833236532888490220123203481892424015537184642439376752630896474493160328325763231266643412666928375071562129281185156830842074816964836301444694877978129857433900347334309803230379471635168720;
    return (xa0+yt4-yt5+rawBias)%p,(xa1+yt4+yt5+rawBias)%p,
           (xa2+yt0+rawBias)%p,(xa3+yt1+rawBias)%p,
           (xa4+yt2+rawBias)%p,(xa5+yt3+rawBias)%p,
           (ya0+xt0+rawBias)%p,(ya1+xt1+rawBias)%p,
           (ya2+xt2+rawBias)%p,(ya3+xt3+rawBias)%p,
           (ya4+xt4+rawBias)%p,(ya5+xt5+rawBias)%p;
}

// The same quotient-preserving line fold after a compile-time Fp2 normalization
// makes c2=1. Fixed-G2 line coefficients use this form.
function lineUnitOneRaw(
    int F0,int F1,int F2,int F3,int F4,int F5,int F6,int F7,int F8,int F9,int F10,int F11,
    int c0a,int c0b,int c1a,int c1b, int u, int v
) returns (int,int,int,int,int,int,int,int,int,int,int,int) {
    int o4a = mulFp(subFp(0, addFp(c0a, c0b), 4), v);
    int o4b = mulFp(subFp(c0a, c0b, 2), v);
    int o5a = mulFp(subFp(0, addFp(c1a, c1b), 2), u);
    int o5b = mulFp(subFp(c1a, c1b, 1), u);
    (int yt0,int yt1,int yt2,int yt3,int yt4,int yt5) =
        fp6Mul12Raw(F6,F7,F8,F9,F10,F11,o4a,o4b,o5a,o5b);
    (int xt0,int xt1,int xt2,int xt3,int xt4,int xt5) =
        fp6Mul12Raw(F0,F1,F2,F3,F4,F5,o4a,o4b,o5a,o5b);
    int p = 4002409555221667393417789825735904156556882819939007885332058136124031650490837864442687629129015664037894272559787;
    int rawBias = 224269951468215875767212481020465616647731681390627737238073383517803674478879000007609185110230708019649361397562390227435454383555896683106802833894510101355302182479805378612229711572948643259859574331488848599599963908852795166;
    return (F0+yt4-yt5+rawBias)%p,(F1+yt4+yt5+rawBias)%p,
           (F2+yt0+rawBias)%p,(F3+yt1+rawBias)%p,
           (F4+yt2+rawBias)%p,(F5+yt3+rawBias)%p,
           (F6+xt0+rawBias)%p,(F7+xt1+rawBias)%p,
           (F8+xt2+rawBias)%p,(F9+xt3+rawBias)%p,
           (F10+xt4+rawBias)%p,(F11+xt5+rawBias)%p;
}

// Fold two consecutive normalized affine lines with one Fp12 Karatsuba layer.
// Each line has implicit c2=1; c0 may use the equivalent representative in [0,2p).
function lineUnitOnePairKaratsubaRaw(
    int F0,int F1,int F2,int F3,int F4,int F5,
    int F6,int F7,int F8,int F9,int F10,int F11,
    int c0a,int c0b,int c1a,int c1b, int u, int v,
    int d0a,int d0b,int d1a,int d1b, int q, int r
) returns (int,int,int,int,int,int,int,int,int,int,int,int) {
    int p = 4002409555221667393417789825735904156556882819939007885332058136124031650490837864442687629129015664037894272559787;

    int s1a = mulFp(4*p-c0a-c0b, v);
    int s1b = mulFp(2*p+c0a-c0b, v);
    int s2a = mulFp(2*p-c1a-c1b, u);
    int s2b = mulFp(p+c1a-c1b, u);
    int t1a = mulFp(4*p-d0a-d0b, r);
    int t1b = mulFp(2*p+d0a-d0b, r);
    int t2a = mulFp(2*p-d1a-d1b, q);
    int t2b = mulFp(p+d1a-d1b, q);

    (int p11a,int p11b) = fp2MulRaw(s1a,s1b,t1a,t1b);
    (int p22a,int p22b) = fp2MulRaw(s2a,s2b,t2a,t2b);
    (int psuma,int psumb) = fp2MulRaw(s1a+s2a,s1b+s2b,t1a+t2a,t1b+t2b);
    int crossa = psuma-p11a-p22a;
    int crossb = psumb-p11b-p22b;
    int pairBias = 96115693486378232471662491865913835706170720595983315959174307221915860490948142860403936475813160579849726313241024383186623307238241435617201214526218614866558078205630876548098447816977989968511246142066649399828555960936912214;
    int st0 = (crossa-crossb+pairBias)%p;
    int st1 = (crossa+crossb+pairBias)%p;
    int st2 = (p22a-p22b+pairBias)%p;
    int st3 = (p22a+p22b+pairBias)%p;
    int st4 = (p11a+pairBias)%p;
    int st5 = (p11b+pairBias)%p;

    int a0a = p+st4-st5+1;
    int a0b = st4+st5;
    int b1a = s1a+t1a; int b1b = s1b+t1b;
    int b2a = s2a+t2a; int b2b = s2b+t2b;

    (int m0,int m1,int m2,int m3,int m4,int m5) =
        fp6MulRaw(F0,F1,F2,F3,F4,F5,a0a,a0b,st0,st1,st2,st3);
    (int n0,int n1,int n2,int n3,int n4,int n5) =
        fp6Mul12Raw(F6,F7,F8,F9,F10,F11,b1a,b1b,b2a,b2b);
    (int k0,int k1,int k2,int k3,int k4,int k5) =
        fp6MulRaw(F0+F6,F1+F7,F2+F8,F3+F9,F4+F10,F5+F11,
                  a0a,a0b,st0+b1a,st1+b1b,st2+b2a,st3+b2b);

    int rawBias = 1922313869727564649433249837318276714123414411919666319183486144438317209818962857208078729516263211596994526264820487663732466144764828712344024290524372297331161564112617530961968956339559799370224922841332987996571119218738244280;
    return (m0+n4-n5+rawBias)%p,(m1+n4+n5+rawBias)%p,
           (m2+n0+rawBias)%p,(m3+n1+rawBias)%p,
           (m4+n2+rawBias)%p,(m5+n3+rawBias)%p,
           (k0-m0-n0+rawBias)%p,(k1-m1-n1+rawBias)%p,
           (k2-m2-n2+rawBias)%p,(k3-m3-n3+rawBias)%p,
           (k4-m4-n4+rawBias)%p,(k5-m5-n5+rawBias)%p;
}

function pointDouble(int Xa,int Xb,int Ya,int Yb,int Za,int Zb)
    returns (int,int,int,int,int,int, int,int,int,int,int,int) {
    (int t0a,int t0b) = fp2Sqr(Ya, Yb);
    (int t1a,int t1b) = fp2Sqr(Za, Zb);
    (int s1a,int s1b) = fp2Scale(t1a, t1b, 3);
    (int t2a,int t2b) = fp2MulByB(s1a, s1b);
    (int t3a,int t3b) = fp2Scale(t2a, t2b, 3);
    (int yza,int yzb) = fp2Add(Ya, Yb, Za, Zb);
    (int sq_a,int sq_b) = fp2Sqr(yza, yzb);
    (int u4a,int u4b) = fp2Sub(sq_a, sq_b, t1a, t1b, 1);
    (int t4a,int t4b) = fp2Sub(u4a, u4b, t0a, t0b, 1);
    (int c0a,int c0b) = fp2Sub(t2a, t2b, t0a, t0b, 1);
    (int rxq_a,int rxq_b) = fp2Sqr(Xa, Xb);
    (int c1a,int c1b) = fp2Scale(rxq_a, rxq_b, 3);
    (int c2a,int c2b) = fp2Neg(t4a, t4b, 3);
    (int da,int db) = fp2Sub(t0a, t0b, t3a, t3b, 1);
    (int dxa,int dxb) = fp2Mul(da, db, Xa, Xb);
    (int dxya,int dxyb) = fp2Mul(dxa, dxb, Ya, Yb);
    (int nxa,int nxb) = fp2Half(dxya, dxyb);
    (int sa,int sb) = fp2Add(t0a, t0b, t3a, t3b);
    (int sha,int shb) = fp2Half(sa, sb);
    (int sh2a,int sh2b) = fp2Sqr(sha, shb);
    (int t2sa,int t2sb) = fp2Sqr(t2a, t2b);
    (int t2s3a,int t2s3b) = fp2Scale(t2sa, t2sb, 3);
    (int nya,int nyb) = fp2Sub(sh2a, sh2b, t2s3a, t2s3b, 1);
    (int nza,int nzb) = fp2Mul(t0a, t0b, t4a, t4b);
    return c0a,c0b,c1a,c1b,c2a,c2b, nxa,nxb,nya,nyb,nza,nzb;
}

function pointAdd(int Xa,int Xb,int Ya,int Yb,int Za,int Zb, int Qxa,int Qxb,int Qya,int Qyb)
    returns (int,int,int,int,int,int, int,int,int,int,int,int) {
    (int qyz_a,int qyz_b) = fp2Mul(Qya, Qyb, Za, Zb);
    (int t0a,int t0b) = fp2Sub(Ya, Yb, qyz_a, qyz_b, 3);
    (int qxz_a,int qxz_b) = fp2Mul(Qxa, Qxb, Za, Zb);
    (int t1a,int t1b) = fp2Sub(Xa, Xb, qxz_a, qxz_b, 3);
    (int t0qx_a,int t0qx_b) = fp2Mul(t0a, t0b, Qxa, Qxb);
    (int t1qy_a,int t1qy_b) = fp2Mul(t1a, t1b, Qya, Qyb);
    (int c0a,int c0b) = fp2Sub(t0qx_a, t0qx_b, t1qy_a, t1qy_b, 3);
    (int c1a,int c1b) = fp2Neg(t0a, t0b, 5);
    int c2a = t1a;
    int c2b = t1b;
    (int t2a,int t2b) = fp2Sqr(t1a, t1b);
    (int t3a,int t3b) = fp2Mul(t2a, t2b, t1a, t1b);
    (int t4a,int t4b) = fp2Mul(t2a, t2b, Xa, Xb);
    (int t42a,int t42b) = fp2Scale(t4a, t4b, 2);
    (int d35a,int d35b) = fp2Sub(t3a, t3b, t42a, t42b, 1);
    (int t0sa,int t0sb) = fp2Sqr(t0a, t0b);
    (int t0sza,int t0szb) = fp2Mul(t0sa, t0sb, Za, Zb);
    (int t5a,int t5b) = fp2Add(d35a, d35b, t0sza, t0szb);
    (int nxa,int nxb) = fp2Mul(t1a, t1b, t5a, t5b);
    (int d45a,int d45b) = fp2Sub(t4a, t4b, t5a, t5b, 7);
    (int d45t0a,int d45t0b) = fp2Mul(d45a, d45b, t0a, t0b);
    (int t3rya,int t3ryb) = fp2Mul(t3a, t3b, Ya, Yb);
    (int nya,int nyb) = fp2Sub(d45t0a, d45t0b, t3rya, t3ryb, 3);
    (int nza,int nzb) = fp2Mul(Za, Zb, t3a, t3b);
    return c0a,c0b,c1a,c1b,c2a,c2b, nxa,nxb,nya,nyb,nza,nzb;
}
