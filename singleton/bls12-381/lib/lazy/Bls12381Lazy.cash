pragma cashscript ^0.14.0;

// BLS12-381 lazy arithmetic: addFp/subFp do not reduce, and each subtraction carries the
// smallest whole-p bias proven for that source location by bound_analysis.mjs. Only products
// reduce. Cashc tree-shakes this union to the functions used by each Miller or residue chunk.
function addFp(int x, int y) returns (int) { return x + y; }

function subFp(int x, int y, int k) returns (int) { return x - y + k * 4002409555221667393417789825735904156556882819939007885332058136124031650490837864442687629129015664037894272559787; }

function mulFp(int x, int y) returns (int) { return (x * y) % 4002409555221667393417789825735904156556882819939007885332058136124031650490837864442687629129015664037894272559787; }

function fp2Add(int a0, int a1, int b0, int b1) returns (int, int) { return addFp(a0, b0), addFp(a1, b1); }

function fp2Sub(int a0, int a1, int b0, int b1, int k) returns (int, int) { return subFp(a0, b0, k), subFp(a1, b1, k); }

function fp2Neg(int a0, int a1, int k) returns (int, int) { return subFp(0, a0, k), subFp(0, a1, k); }

function fp2Mul(int a0, int a1, int b0, int b1) returns (int, int) {
    // bound_analysis.mjs first retains the removed lazy kernel's output envelope, proving every
    // input below 310p without assuming these reductions. Hence 76880p^2 covers a1*b1.
    int p = 4002409555221667393417789825735904156556882819939007885332058136124031650490837864442687629129015664037894272559787;
    int nonnegativeBias = 1231562419205459752070235395775242614848400833236532888490220123203481892424015537184642439376752630896474493160328325763231266643412666928375071562129281185156830842074816964836301444694877978129857433900347334309803230379471635168720;
    int v0 = a0 * b0;
    int v1 = a1 * b1;
    int cross = (a0 + a1) * (b0 + b1) - v0 - v1;
    return (v0 - v1 + nonnegativeBias) % p, cross % p;
}

function fp2Sqr(int a0, int a1) returns (int, int) {
    // bound_analysis.mjs proves a0,a1 < 124p, so (a0+a0)*a1 < 30752p^2,
    // below the already-audited 76880p^2 fp2Mul envelope.
    return mulFp(addFp(a0, a1), subFp(a0, a1, 124)), mulFp(addFp(a0, a0), a1);
}

function fp2Scale(int a0, int a1, int k) returns (int, int) { return mulFp(a0, k), mulFp(a1, k); }

function fp2MulXi(int a0, int a1, int k) returns (int, int) { return subFp(a0, a1, k), addFp(a0, a1); }

function fp2MulByB(int a0, int a1) returns (int, int) {
    int f0 = mulFp(a0, 4);
    int f1 = mulFp(a1, 4);
    return subFp(f0, f1, 1), addFp(f0, f1);
}

function fp2Half(int a0, int a1) returns (int, int) {
    return mulFp(a0, 2001204777610833696708894912867952078278441409969503942666029068062015825245418932221343814564507832018947136279894),
           mulFp(a1, 2001204777610833696708894912867952078278441409969503942666029068062015825245418932221343814564507832018947136279894);
}

function fp2Conj(int a0, int a1, int k) returns (int, int) { return a0, subFp(0, a1, k); }

function fp6Add(int a0a,int a0b,int a1a,int a1b,int a2a,int a2b,int b0a,int b0b,int b1a,int b1b,int b2a,int b2b) returns (int,int,int,int,int,int) {
    (int c0a, int c0b) = fp2Add(a0a, a0b, b0a, b0b);
    (int c1a, int c1b) = fp2Add(a1a, a1b, b1a, b1b);
    (int c2a, int c2b) = fp2Add(a2a, a2b, b2a, b2b);
    return c0a, c0b, c1a, c1b, c2a, c2b;
}

function fp6Sub(int a0a,int a0b,int a1a,int a1b,int a2a,int a2b,int b0a,int b0b,int b1a,int b1b,int b2a,int b2b, int k) returns (int,int,int,int,int,int) {
    (int c0a, int c0b) = fp2Sub(a0a, a0b, b0a, b0b, k);
    (int c1a, int c1b) = fp2Sub(a1a, a1b, b1a, b1b, k);
    (int c2a, int c2b) = fp2Sub(a2a, a2b, b2a, b2b, k);
    return c0a, c0b, c1a, c1b, c2a, c2b;
}

function fp6Neg(int a0a,int a0b,int a1a,int a1b,int a2a,int a2b, int k) returns (int,int,int,int,int,int) {
    (int c0a, int c0b) = fp2Neg(a0a, a0b, k);
    (int c1a, int c1b) = fp2Neg(a1a, a1b, k);
    (int c2a, int c2b) = fp2Neg(a2a, a2b, k);
    return c0a, c0b, c1a, c1b, c2a, c2b;
}

function fp6MulByV(int a0a,int a0b,int a1a,int a1b,int a2a,int a2b, int k) returns (int,int,int,int,int,int) {
    (int n0a, int n0b) = fp2MulXi(a2a, a2b, k);
    return n0a, n0b, a0a, a0b, a1a, a1b;
}

function fp6Mul(int a0a,int a0b,int a1a,int a1b,int a2a,int a2b,int b0a,int b0b,int b1a,int b1b,int b2a,int b2b) returns (int,int,int,int,int,int) {
    (int t0a, int t0b) = fp2Mul(a0a, a0b, b0a, b0b);
    (int t1a, int t1b) = fp2Mul(a1a, a1b, b1a, b1b);
    (int t2a, int t2b) = fp2Mul(a2a, a2b, b2a, b2b);
    (int s1a, int s1b) = fp2Add(a1a, a1b, a2a, a2b);
    (int s2a, int s2b) = fp2Add(b1a, b1b, b2a, b2b);
    (int p1a, int p1b) = fp2Mul(s1a, s1b, s2a, s2b);
    (int d1a, int d1b) = fp2Sub(p1a, p1b, t1a, t1b, 3);
    (int d2a, int d2b) = fp2Sub(d1a, d1b, t2a, t2b, 3);
    (int x1a, int x1b) = fp2MulXi(d2a, d2b, 9);
    (int c0a, int c0b) = fp2Add(t0a, t0b, x1a, x1b);
    (int s3a, int s3b) = fp2Add(a0a, a0b, a1a, a1b);
    (int s4a, int s4b) = fp2Add(b0a, b0b, b1a, b1b);
    (int p2a, int p2b) = fp2Mul(s3a, s3b, s4a, s4b);
    (int d3a, int d3b) = fp2Sub(p2a, p2b, t0a, t0b, 3);
    (int d4a, int d4b) = fp2Sub(d3a, d3b, t1a, t1b, 3);
    (int x2a, int x2b) = fp2MulXi(t2a, t2b, 3);
    (int c1a, int c1b) = fp2Add(d4a, d4b, x2a, x2b);
    (int s5a, int s5b) = fp2Add(a0a, a0b, a2a, a2b);
    (int s6a, int s6b) = fp2Add(b0a, b0b, b2a, b2b);
    (int p3a, int p3b) = fp2Mul(s5a, s5b, s6a, s6b);
    (int d5a, int d5b) = fp2Sub(p3a, p3b, t0a, t0b, 3);
    (int d6a, int d6b) = fp2Sub(d5a, d5b, t2a, t2b, 3);
    (int c2a, int c2b) = fp2Add(d6a, d6b, t1a, t1b);
    return c0a, c0b, c1a, c1b, c2a, c2b;
}

// Unreduced tower products used by the fused-output Miller kernels below. Keeping the
// internal products signed and reducing only the twelve externally visible limbs avoids
// repeatedly normalizing values which are consumed immediately by the same field operation.
function fp2MulRaw(int a0, int a1, int b0, int b1) returns (int, int) {
    int v0 = a0 * b0;
    int v1 = a1 * b1;
    return v0 - v1, (a0 + a1) * (b0 + b1) - v0 - v1;
}

function fp6MulRaw(int a0a,int a0b,int a1a,int a1b,int a2a,int a2b,int b0a,int b0b,int b1a,int b1b,int b2a,int b2b) returns (int,int,int,int,int,int) {
    (int t0a,int t0b) = fp2MulRaw(a0a,a0b,b0a,b0b);
    (int t1a,int t1b) = fp2MulRaw(a1a,a1b,b1a,b1b);
    (int t2a,int t2b) = fp2MulRaw(a2a,a2b,b2a,b2b);

    (int p1a,int p1b) = fp2MulRaw(a1a+a2a,a1b+a2b,b1a+b2a,b1b+b2b);
    int d1a = p1a - t1a - t2a;
    int d1b = p1b - t1b - t2b;
    int c0a = t0a + d1a - d1b;
    int c0b = t0b + d1a + d1b;

    (int p2a,int p2b) = fp2MulRaw(a0a+a1a,a0b+a1b,b0a+b1a,b0b+b1b);
    int d2a = p2a - t0a - t1a;
    int d2b = p2b - t0b - t1b;
    int c1a = d2a + t2a - t2b;
    int c1b = d2b + t2a + t2b;

    (int p3a,int p3b) = fp2MulRaw(a0a+a2a,a0b+a2b,b0a+b2a,b0b+b2b);
    int c2a = p3a - t0a - t2a + t1a;
    int c2b = p3b - t0b - t2b + t1b;
    return c0a,c0b,c1a,c1b,c2a,c2b;
}

// Multiply a dense Fp6 value by b1*V+b2*V^2 in five Fp2 products.
function fp6Mul12Raw(int a0a,int a0b,int a1a,int a1b,int a2a,int a2b,int b1a,int b1b,int b2a,int b2b) returns (int,int,int,int,int,int) {
    (int p1a,int p1b) = fp2MulRaw(a1a,a1b,b1a,b1b);
    (int p2a,int p2b) = fp2MulRaw(a2a,a2b,b2a,b2b);
    (int pa,int pb) = fp2MulRaw(a1a+a2a,a1b+a2b,b1a+b2a,b1b+b2b);
    int crossa = pa - p1a - p2a;
    int crossb = pb - p1b - p2b;
    (int a0b1a,int a0b1b) = fp2MulRaw(a0a,a0b,b1a,b1b);
    (int a0b2a,int a0b2b) = fp2MulRaw(a0a,a0b,b2a,b2b);
    return crossa-crossb,crossa+crossb,
           a0b1a+p2a-p2b,a0b1b+p2a+p2b,
           a0b2a+p1a,a0b2b+p1b;
}

function fp6Mul01(int c0a,int c0b,int c1a,int c1b,int c2a,int c2b, int b0a,int b0b,int b1a,int b1b) returns (int,int,int,int,int,int) {
    (int t0a,int t0b) = fp2Mul(c0a, c0b, b0a, b0b);
    (int t1a,int t1b) = fp2Mul(c1a, c1b, b1a, b1b);
    (int s12a,int s12b) = fp2Add(c1a, c1b, c2a, c2b);
    (int m12a,int m12b) = fp2Mul(s12a, s12b, b1a, b1b);
    (int u0a,int u0b) = fp2Sub(m12a, m12b, t1a, t1b, 3);
    (int xu0a,int xu0b) = fp2MulXi(u0a, u0b, 6);
    (int r0a,int r0b) = fp2Add(xu0a, xu0b, t0a, t0b);
    (int sba,int sbb) = fp2Add(b0a, b0b, b1a, b1b);
    (int sca,int scb) = fp2Add(c0a, c0b, c1a, c1b);
    (int m1a,int m1b) = fp2Mul(sba, sbb, sca, scb);
    (int u1a,int u1b) = fp2Sub(m1a, m1b, t0a, t0b, 3);
    (int r1a,int r1b) = fp2Sub(u1a, u1b, t1a, t1b, 3);
    (int s02a,int s02b) = fp2Add(c0a, c0b, c2a, c2b);
    (int m2a,int m2b) = fp2Mul(s02a, s02b, b0a, b0b);
    (int u2a,int u2b) = fp2Sub(m2a, m2b, t0a, t0b, 3);
    (int r2a,int r2b) = fp2Add(u2a, u2b, t1a, t1b);
    return r0a, r0b, r1a, r1b, r2a, r2b;
}

function fp6Mul1(int c0a,int c0b,int c1a,int c1b,int c2a,int c2b, int b1a,int b1b) returns (int,int,int,int,int,int) {
    (int m2a,int m2b) = fp2Mul(c2a, c2b, b1a, b1b);
    (int r0a,int r0b) = fp2MulXi(m2a, m2b, 3);
    (int r1a,int r1b) = fp2Mul(c0a, c0b, b1a, b1b);
    (int r2a,int r2b) = fp2Mul(c1a, c1b, b1a, b1b);
    return r0a, r0b, r1a, r1b, r2a, r2b;
}

function fp6FrobOdd(int x0a,int x0b,int x1a,int x1b,int x2a,int x2b, int k1a,int k1b,int k2a,int k2b) returns (int,int,int,int,int,int) {
    (int d0a,int d0b) = fp2Conj(x0a, x0b, 62);
    (int c1a,int c1b) = fp2Conj(x1a, x1b, 62);
    (int d1a,int d1b) = fp2Mul(c1a, c1b, k1a, k1b);
    (int c2a,int c2b) = fp2Conj(x2a, x2b, 62);
    (int d2a,int d2b) = fp2Mul(c2a, c2b, k2a, k2b);
    return d0a, d0b, d1a, d1b, d2a, d2b;
}

function fp6FrobEven(int x0a,int x0b,int x1a,int x1b,int x2a,int x2b, int k1a,int k1b,int k2a,int k2b) returns (int,int,int,int,int,int) {
    (int d1a,int d1b) = fp2Mul(x1a, x1b, k1a, k1b);
    (int d2a,int d2b) = fp2Mul(x2a, x2b, k2a, k2b);
    return x0a, x0b, d1a, d1b, d2a, d2b;
}

function fp6MulByFp2(int x0a,int x0b,int x1a,int x1b,int x2a,int x2b, int ka,int kb) returns (int,int,int,int,int,int) {
    (int r0a,int r0b) = fp2Mul(x0a, x0b, ka, kb);
    (int r1a,int r1b) = fp2Mul(x1a, x1b, ka, kb);
    (int r2a,int r2b) = fp2Mul(x2a, x2b, ka, kb);
    return r0a, r0b, r1a, r1b, r2a, r2b;
}

function fp12Sqr(
    int A0,int A1,int A2,int A3,int A4,int A5, int A6,int A7,int A8,int A9,int A10,int A11
) returns (int,int,int,int,int,int,int,int,int,int,int,int) {
    (int t0_0,int t0_1,int t0_2,int t0_3,int t0_4,int t0_5) = fp6Mul(A0,A1,A2,A3,A4,A5, A6,A7,A8,A9,A10,A11);
    (int s0,int s1,int s2,int s3,int s4,int s5) = fp6Add(A0,A1,A2,A3,A4,A5, A6,A7,A8,A9,A10,A11);
    (int vc0,int vc1,int vc2,int vc3,int vc4,int vc5) = fp6MulByV(A6,A7,A8,A9,A10,A11, 62);
    (int u0,int u1,int u2,int u3,int u4,int u5) = fp6Add(A0,A1,A2,A3,A4,A5, vc0,vc1,vc2,vc3,vc4,vc5);
    (int t1_0,int t1_1,int t1_2,int t1_3,int t1_4,int t1_5) = fp6Mul(s0,s1,s2,s3,s4,s5, u0,u1,u2,u3,u4,u5);
    (int C6,int C7,int C8,int C9,int C10,int C11) = fp6Add(t0_0,t0_1,t0_2,t0_3,t0_4,t0_5, t0_0,t0_1,t0_2,t0_3,t0_4,t0_5);
    (int vt0,int vt1,int vt2,int vt3,int vt4,int vt5) = fp6MulByV(t0_0,t0_1,t0_2,t0_3,t0_4,t0_5, 12);
    (int d0,int d1,int d2,int d3,int d4,int d5) = fp6Sub(t1_0,t1_1,t1_2,t1_3,t1_4,t1_5, t0_0,t0_1,t0_2,t0_3,t0_4,t0_5, 20);
    (int C0,int C1,int C2,int C3,int C4,int C5) = fp6Sub(d0,d1,d2,d3,d4,d5, vt0,vt1,vt2,vt3,vt4,vt5, 22);
    return C0,C1,C2,C3,C4,C5,C6,C7,C8,C9,C10,C11;
}

function fp12SqrRaw(
    int A0,int A1,int A2,int A3,int A4,int A5, int A6,int A7,int A8,int A9,int A10,int A11
) returns (int,int,int,int,int,int,int,int,int,int,int,int) {
    (int t0,int t1,int t2,int t3,int t4,int t5) =
        fp6MulRaw(A0,A1,A2,A3,A4,A5, A6,A7,A8,A9,A10,A11);
    (int q0,int q1,int q2,int q3,int q4,int q5) =
        fp6MulRaw(A0+A6,A1+A7,A2+A8,A3+A9,A4+A10,A5+A11,
                  A0+A10-A11,A1+A10+A11,A2+A6,A3+A7,A4+A8,A5+A9);
    int p = 4002409555221667393417789825735904156556882819939007885332058136124031650490837864442687629129015664037894272559787;
    int rawBias = 1377658273304754665427162383411431645121780328542427528748165070180794000370256714332456422819988634977846077156454682825674934070414793910513217408209133479753999120947375897189411085376684522881994528036288641397542635440095741734;
    return (q0-t0-t4+t5+rawBias)%p, (q1-t1-t4-t5+rawBias)%p,
           (q2-t2-t0+rawBias)%p, (q3-t3-t1+rawBias)%p,
           (q4-t4-t2+rawBias)%p, (q5-t5-t3+rawBias)%p,
           (t0+t0+rawBias)%p, (t1+t1+rawBias)%p,
           (t2+t2+rawBias)%p, (t3+t3+rawBias)%p,
           (t4+t4+rawBias)%p, (t5+t5+rawBias)%p;
}

function fp12Mul(
    int A0,int A1,int A2,int A3,int A4,int A5, int A6,int A7,int A8,int A9,int A10,int A11,
    int B0,int B1,int B2,int B3,int B4,int B5, int B6,int B7,int B8,int B9,int B10,int B11
) returns (int,int,int,int,int,int,int,int,int,int,int,int) {
    (int t0_0,int t0_1,int t0_2,int t0_3,int t0_4,int t0_5) = fp6Mul(A0,A1,A2,A3,A4,A5, B0,B1,B2,B3,B4,B5);
    (int t1_0,int t1_1,int t1_2,int t1_3,int t1_4,int t1_5) = fp6Mul(A6,A7,A8,A9,A10,A11, B6,B7,B8,B9,B10,B11);
    (int vt_0,int vt_1,int vt_2,int vt_3,int vt_4,int vt_5) = fp6MulByV(t1_0,t1_1,t1_2,t1_3,t1_4,t1_5, 12);
    (int C0,int C1,int C2,int C3,int C4,int C5) = fp6Add(t0_0,t0_1,t0_2,t0_3,t0_4,t0_5, vt_0,vt_1,vt_2,vt_3,vt_4,vt_5);
    (int sa_0,int sa_1,int sa_2,int sa_3,int sa_4,int sa_5) = fp6Add(A0,A1,A2,A3,A4,A5, A6,A7,A8,A9,A10,A11);
    (int sb_0,int sb_1,int sb_2,int sb_3,int sb_4,int sb_5) = fp6Add(B0,B1,B2,B3,B4,B5, B6,B7,B8,B9,B10,B11);
    (int pr_0,int pr_1,int pr_2,int pr_3,int pr_4,int pr_5) = fp6Mul(sa_0,sa_1,sa_2,sa_3,sa_4,sa_5, sb_0,sb_1,sb_2,sb_3,sb_4,sb_5);
    (int qq_0,int qq_1,int qq_2,int qq_3,int qq_4,int qq_5) = fp6Sub(pr_0,pr_1,pr_2,pr_3,pr_4,pr_5, t0_0,t0_1,t0_2,t0_3,t0_4,t0_5, 20);
    (int C6,int C7,int C8,int C9,int C10,int C11) = fp6Sub(qq_0,qq_1,qq_2,qq_3,qq_4,qq_5, t1_0,t1_1,t1_2,t1_3,t1_4,t1_5, 20);
    return C0,C1,C2,C3,C4,C5,C6,C7,C8,C9,C10,C11;
}

function fp12Conj(int A0,int A1,int A2,int A3,int A4,int A5, int A6,int A7,int A8,int A9,int A10,int A11)
    returns (int,int,int,int,int,int,int,int,int,int,int,int) {
    (int N6,int N7,int N8,int N9,int N10,int N11) = fp6Neg(A6,A7,A8,A9,A10,A11, 62);
    return A0,A1,A2,A3,A4,A5,N6,N7,N8,N9,N10,N11;
}

